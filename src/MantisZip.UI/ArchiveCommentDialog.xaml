<Window x:Class="MantisZip.UI.ArchiveCommentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L Main_ArchiveComment_Title}" Height="350" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Theme_WindowBg}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 提示文本 -->
        <TextBlock Grid.Row="0" Text="{l:L Main_ArchiveComment_Prompt}" 
                   Margin="0,0,0,8"/>

        <!-- 注释编辑框 -->
        <TextBox x:Name="CommentTextBox" Grid.Row="1"
                 AcceptsReturn="True" 
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Padding="8"
                 Background="{StaticResource Theme_SurfaceBg}"
                 Foreground="{StaticResource Theme_TextPrimary}"
                 BorderBrush="{StaticResource Theme_Border}"
                 BorderThickness="1"/>

        <!-- 格式提示 -->
        <TextBlock Grid.Row="2" 
                   Text="{l:L Main_ArchiveComment_ZipOnly}"
                   Foreground="{StaticResource Theme_TextDisabled}"
                   FontSize="12"
                   Margin="0,8,0,0"/>

        <!-- 按钮行 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{l:L MsgBox_Cancel}" 
                    Click="Cancel_Click" 
                    Width="80" Height="30" Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button Content="{l:L Main_ArchiveComment_Save}" 
                    Click="Save_Click" 
                    Width="80" Height="30"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
