<Window x:Class="MantisZip.UI.PasswordManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="密码管理器 - MantisZip" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="➕ 添加" Click="Add_Click" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="✏️ 编辑" Click="Edit_Click" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="🗑️ 删除" Click="Delete_Click" Padding="12,6"/>
            <Border Width="1" Background="#CCC" Margin="16,4,12,4"/>
            <Button x:Name="ShowPwdBtn" Content="👁 显示密码" Click="ToggleShowPasswords_Click"
                    Padding="12,6" Margin="0,0,8,0"
                    BorderThickness="1" BorderBrush="#CCC" Background="#F0F0F0"/>
            <Button Content="?" FontWeight="Bold" FontSize="14" Width="28" Height="28"
                    ToolTip="查看匹配规则帮助" Click="Help_Click"
                    BorderThickness="1" BorderBrush="#CCC" Background="#F0F0F0"/>
        </StackPanel>

        <!-- Password List -->
        <DataGrid Grid.Row="1" x:Name="PasswordGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  BorderThickness="1"
                  BorderBrush="#DDD">
            <DataGrid.Columns>
                <DataGridTextColumn Header="密码" Binding="{Binding Password}" Width="120"/>
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="150"/>
                <DataGridTextColumn Header="匹配规则" Binding="{Binding PatternDisplay}" Width="*"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd'}" Width="100"/>
                <DataGridTextColumn Header="上次使用" Binding="{Binding LastUsed, StringFormat='yyyy-MM-dd'}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Note -->
        <TextBlock Grid.Row="2" Text="💡 点击工具栏 ? 按钮查看匹配规则详细说明" 
                  Foreground="Gray" Margin="0,12,0,0"/>
    </Grid>
</Window>