<Window x:Class="MantisZip.UI.PasswordManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L PwdMgr_Title}" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="{l:L PwdMgr_Add}" Click="Add_Click" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="{l:L PwdMgr_Edit}" Click="Edit_Click" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="{l:L PwdMgr_Delete}" Click="Delete_Click" Padding="12,6"/>
            <Border Width="1" Background="#CCC" Margin="16,4,12,4"/>
            <Button x:Name="ShowPwdBtn" Content="{l:L PwdMgr_ShowPwd}" Click="ToggleShowPasswords_Click"
                    Padding="12,6" Margin="0,0,8,0"
                    BorderThickness="1" BorderBrush="#CCC" Background="#F0F0F0"/>
            <Button Content="?" FontWeight="Bold" FontSize="14" Width="28" Height="28"
                    ToolTip="{l:L PwdMgr_Help_Tooltip}" Click="Help_Click"
                    BorderThickness="1" BorderBrush="#CCC" Background="#F0F0F0"/>
        </StackPanel>

        <!-- Password List -->
        <DataGrid Grid.Row="1" x:Name="PasswordGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  BorderThickness="1"
                  BorderBrush="#DDD">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{l:L PwdMgr_Col_Password}" Binding="{Binding Password}" Width="120"/>
                <DataGridTextColumn Header="{l:L PwdMgr_Col_Description}" Binding="{Binding Description}" Width="150"/>
                <DataGridTextColumn Header="{l:L PwdMgr_Col_Rules}" Binding="{Binding PatternDisplay}" Width="*"/>
                <DataGridTextColumn Header="{l:L PwdMgr_Col_Created}" Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd'}" Width="100"/>
                <DataGridTextColumn Header="{l:L PwdMgr_Col_LastUsed}" Binding="{Binding LastUsed, StringFormat='yyyy-MM-dd'}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Note -->
        <TextBlock Grid.Row="2" Text="{l:L PwdMgr_Tip}" 
                  Foreground="Gray" Margin="0,12,0,0"/>
    </Grid>
</Window>