<Window x:Class="MantisZip.UI.PasswordEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L PwdEdit_Title}" Height="380" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{l:L PwdEdit_PasswordLabel}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="PasswordBox" FontSize="14" Padding="8,6"/>

        <TextBlock Grid.Row="2" Text="{l:L PwdEdit_DescriptionLabel}" Margin="0,12,0,4"/>
        <TextBox Grid.Row="3" x:Name="DescriptionBox" FontSize="14" Padding="8,6"/>

        <TextBlock Grid.Row="4" Text="{l:L PwdEdit_RulesLabel}" Margin="0,12,0,4"/>
        
        <Border Grid.Row="5" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,12">
            <TextBox x:Name="PatternsBox" AcceptsReturn="True" TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Padding="8,6"/>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{l:L PwdEdit_Save}" Click="Save_Click" Width="80" Height="32" Margin="0,0,8,0" 
                    IsDefault="True" Background="#2196F3" Foreground="White"/>
            <Button Content="{l:L MsgBox_Cancel}" Click="Cancel_Click" Width="80" Height="32" 
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>