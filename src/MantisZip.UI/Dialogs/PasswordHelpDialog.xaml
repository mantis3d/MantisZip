<Window x:Class="MantisZip.UI.PasswordHelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L PwdHelp_Title}" Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Theme_WindowBg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- 简介 -->
            <TextBlock Text="{l:L PwdHelp_Section_Title}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="{l:L PwdHelp_Intro}" TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="22"/>

            <!-- Glob 匹配 -->
            <TextBlock Text="{l:L PwdHelp_Glob_Title}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="{StaticResource Theme_SurfaceBg}" CornerRadius="4" Padding="14" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:L PwdHelp_Glob_Col_Wildcard}" FontWeight="Bold" Width="120"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{l:L PwdHelp_Regex_Col_Meaning}" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="  *" FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{l:L PwdHelp_Glob_MatchAny}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="  ?" FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{l:L PwdHelp_Glob_MatchSingle}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="  ." FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{l:L PwdHelp_Glob_MatchDot}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{l:L PwdHelp_Glob_OtherChars}" FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{l:L PwdHelp_Glob_MatchLiteral}"/>
                    </Grid>

                    <TextBlock Text="{l:L PwdHelp_Regex_Examples_Title}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="{StaticResource Theme_SurfaceBg}" CornerRadius="4" Padding="10" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="*.zip" FontWeight="Bold" Foreground="{StaticResource Theme_Accent}"/>
                                <Run Text="{l:L PwdHelp_Glob_Example_AllZip}"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="{l:L PwdHelp_Glob_Example_DocStar}" FontWeight="Bold" Foreground="{StaticResource Theme_Accent}"/>
                                <Run Text="{l:L PwdHelp_Glob_Example_DocStarDesc}"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="???.zip" FontWeight="Bold" Foreground="{StaticResource Theme_Accent}"/>
                                <Run Text="{l:L PwdHelp_Glob_Example_ThreeChars}"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13">
                                <Run Text="{l:L PwdHelp_Glob_Example_Backup}" FontWeight="Bold" Foreground="{StaticResource Theme_Accent}"/>
                                <Run Text="{l:L PwdHelp_Glob_Example_BackupDesc}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Regex 匹配 -->
            <TextBlock Text="{l:L PwdHelp_Regex_Title}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="{StaticResource Theme_SurfaceBg}" CornerRadius="4" Padding="14" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:L PwdHelp_Regex_Col_Pattern}" FontWeight="Bold" Width="120"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{l:L PwdHelp_Regex_Col_Meaning}" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="  \d" FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{l:L PwdHelp_Regex_Digit}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="  \w" FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{l:L PwdHelp_Regex_Word}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="  [a-z]" FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{l:L PwdHelp_Regex_CharSet}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="  ^...$" FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{l:L PwdHelp_Regex_Anchors}"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="  |" FontFamily="Consolas" Foreground="{StaticResource Theme_Accent}"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{l:L PwdHelp_Regex_Or}"/>
                    </Grid>

                    <TextBlock Text="{l:L PwdHelp_Regex_Examples_Title}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="{StaticResource Theme_SurfaceBg}" CornerRadius="4" Padding="10" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="{l:L PwdHelp_Regex_Ex_Finance}" FontWeight="Bold" Foreground="{StaticResource Theme_Accent}"/>
                                <Run Text="{l:L PwdHelp_Regex_Ex_FinanceDesc}"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="\.rar$" FontWeight="Bold" Foreground="{StaticResource Theme_Accent}"/>
                                <Run Text="{l:L PwdHelp_Regex_Ex_Rar}"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="202[0-9]\.zip" FontWeight="Bold" Foreground="{StaticResource Theme_Accent}"/>
                                <Run Text="{l:L PwdHelp_Regex_Ex_Year}"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13">
                                <Run Text="{l:L PwdHelp_Regex_Ex_Project}" FontWeight="Bold" Foreground="{StaticResource Theme_Accent}"/>
                                <Run Text="{l:L PwdHelp_Regex_Ex_ProjectDesc}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 匹配顺序说明 -->
            <TextBlock Text="{l:L PwdHelp_Match_Title}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="{StaticResource Theme_SurfaceBg}" CornerRadius="4" Padding="14" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,6">
                        <Run Text="{l:L PwdHelp_Match_Step1}"/><LineBreak/>
                        <Run Text="{l:L PwdHelp_Match_Step2}"/><LineBreak/>
                        <Run Text="{l:L PwdHelp_Match_Step3}"/><LineBreak/>
                        <Run Text="{l:L PwdHelp_Match_Step4}"/><LineBreak/>
                        <Run Text="{l:L PwdHelp_Match_Step5}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 关闭按钮 -->
            <Button Content="{l:L PwdHelp_Close}" Click="Close_Click" Width="100" Height="32" 
                    HorizontalAlignment="Right" IsDefault="True"
                    Background="{StaticResource Theme_Accent}" Foreground="{StaticResource Theme_TextOnAccent}" Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>
</Window>
