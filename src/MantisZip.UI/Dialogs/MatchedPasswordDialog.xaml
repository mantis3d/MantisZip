<Window x:Class="MantisZip.UI.MatchedPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L PwdMatched_Title}" Height="Auto" Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Theme_WindowBg}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: header -->
            <RowDefinition Height="Auto"/>  <!-- 1: password row -->
            <RowDefinition Height="Auto"/>  <!-- 2: rules -->
            <RowDefinition Height="Auto"/>  <!-- 3: description -->
            <RowDefinition Height="Auto"/>  <!-- 4: close button -->
        </Grid.RowDefinitions>

        <!-- Header: filename -->
        <TextBlock x:Name="HeaderText" Grid.Row="0"
                   FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

        <!-- Password row: icon + masked text + reveal + copy -->
        <Border Grid.Row="1"
                Background="{StaticResource Theme_StatusSuccessBg}"
                BorderBrush="{StaticResource Theme_StatusSuccess}"
                BorderThickness="1" CornerRadius="4" Padding="8,6"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔑" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>

                <!-- Password display -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="PwdMaskedText"
                               Text="●●●●●●●●●●" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Theme_TextPrimary}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="PwdPlainText"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Theme_TextPrimary}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>

                <Button x:Name="PwdRevealBtn" Grid.Column="2"
                        Width="24" Height="22" Margin="4,0,0,0"
                        Content="👁" FontSize="10" Padding="0"
                        Background="{StaticResource Theme_ButtonBg}" BorderThickness="1"
                        BorderBrush="{StaticResource Theme_Border}" Foreground="{StaticResource Theme_TextSecondary}"
                        Cursor="Hand" ToolTip="{l:L PwdMgr_Col_Password}"
                        Click="PwdRevealBtn_Click"/>

                <Button x:Name="PwdCopyBtn" Grid.Column="3"
                        Width="24" Height="22" Margin="4,0,0,0"
                        Content="📋" FontSize="10" Padding="0"
                        Background="{StaticResource Theme_ButtonBg}" BorderThickness="1"
                        BorderBrush="{StaticResource Theme_Border}" Foreground="{StaticResource Theme_TextSecondary}"
                        Cursor="Hand" ToolTip="{l:L PwdMgr_Col_Password}"
                        Click="PwdCopyBtn_Click"/>
            </Grid>
        </Border>

        <!-- Rules section -->
        <Border x:Name="RulesSection" Grid.Row="2"
                Visibility="Collapsed" Margin="22,0,0,4">
            <TextBlock x:Name="RulesText" FontSize="11"
                       Foreground="{StaticResource Theme_TextDisabled}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Description section -->
        <Border x:Name="DescriptionSection" Grid.Row="3"
                Visibility="Collapsed" Margin="22,0,0,12">
            <TextBlock x:Name="DescriptionText" FontSize="11"
                       Foreground="{StaticResource Theme_TextDisabled}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Close button -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{l:L MsgBox_Ok}" Click="Close_Click"
                    Width="80" Height="30"
                    IsDefault="True"
                    Background="{StaticResource Theme_Accent}" Foreground="{StaticResource Theme_TextOnAccent}"/>
        </StackPanel>
    </Grid>
</Window>
