<Window x:Class="MantisZip.UI.ConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="{l:L Conflict_Title}" Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Theme_WindowBg}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>  <!-- Row 7: 自定义重命名输入 -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- Row 9: 应用到全部 -->
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <TextBlock x:Name="HeaderText" Grid.Row="0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Theme_TextPrimary}"/>

        <!-- Row 2: Comparison panel -->
        <Border Grid.Row="2" Background="{StaticResource Theme_SurfaceBg}" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1" CornerRadius="4" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{l:L Conflict_DiskLabel}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme_TextSecondary}" Margin="0,0,0,6"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" LineHeight="18">
                        <Run Text="{l:L Conflict_SizeLabel}"/><Run x:Name="ExistingSizeText" Foreground="{StaticResource Theme_TextDisabled}"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" LineHeight="18">
                        <Run Text="{l:L Conflict_DateLabel}"/><Run x:Name="ExistingDateText" Foreground="{StaticResource Theme_TextDisabled}"/>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource Theme_StatusWarning}" CornerRadius="10"
                        Width="32" Height="22" Margin="12,10"
                        HorizontalAlignment="Center" VerticalAlignment="Top">
                    <TextBlock Text="VS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Theme_TextPrimary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{l:L Conflict_ArchiveLabel}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme_TextSecondary}" Margin="0,0,0,6"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" LineHeight="18">
                        <Run Text="{l:L Conflict_SizeLabel}"/><Run x:Name="EntrySizeText" Foreground="{StaticResource Theme_Accent}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" LineHeight="18">
                        <Run Text="{l:L Conflict_DateLabel}"/><Run x:Name="EntryDateText" Foreground="{StaticResource Theme_Accent}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 4: Comparison result -->
        <TextBlock x:Name="CompareResultText" Grid.Row="4" FontSize="11" Foreground="{StaticResource Theme_TextSecondary}"
                   TextWrapping="Wrap" HorizontalAlignment="Center"/>

        <!-- Row 6: Buttons -->
        <WrapPanel Grid.Row="6" HorizontalAlignment="Center">
            <Button Height="Auto" Padding="6,4" MinWidth="70" Click="Overwrite_Click"
                    Background="{StaticResource Theme_ButtonBg}" BorderBrush="{StaticResource Theme_Border}" BorderThickness="1" Margin="0,0,4,4">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <emoji:TextBlock Text="🔄" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="{l:L CompressConflict_Overwrite}" FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Height="Auto" Padding="6,4" MinWidth="70" Click="OverwriteIfOlder_Click"
                    Background="{StaticResource Theme_ButtonBg}" BorderBrush="{StaticResource Theme_Border}" BorderThickness="1" Margin="4,0,4,4">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <emoji:TextBlock Text="🕐" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="{l:L Conflict_Btn_OverwriteOlder}" FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Height="Auto" Padding="6,4" MinWidth="70" Click="OverwriteIfSmaller_Click"
                    Background="{StaticResource Theme_ButtonBg}" BorderBrush="{StaticResource Theme_Border}" BorderThickness="1" Margin="4,0,4,4">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <emoji:TextBlock Text="⬇️" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="{l:L Conflict_Btn_OverwriteSmaller}" FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Height="Auto" Padding="6,4" MinWidth="70" Click="Rename_Click"
                    Background="{StaticResource Theme_ButtonBg}" BorderBrush="{StaticResource Theme_Border}" BorderThickness="1" Margin="4,0,4,4">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <emoji:TextBlock Text="✏️" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="{l:L Conflict_Btn_Rename}" FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Height="Auto" Padding="6,4" MinWidth="70" Click="Skip_Click"
                    Background="{StaticResource Theme_ButtonBg}" BorderBrush="{StaticResource Theme_Border}" BorderThickness="1" Margin="4,0,0,4">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <emoji:TextBlock Text="⏭️" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="{l:L Error_Skip}" FontSize="11" Foreground="{StaticResource Theme_TextPrimary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
        </WrapPanel>

        <!-- Row 7: 自定义重命名输入（勾选"应用到全部"时禁用） -->
        <Grid Grid.Row="7" HorizontalAlignment="Stretch" Margin="30,0,30,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{l:L Conflict_NewNameLabel}" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Theme_TextSecondary}"/>
            <TextBox Grid.Column="1" x:Name="RenameTextBox" FontSize="12" Padding="3,2"/>
        </Grid>

        <!-- Row 9: Checkbox -->
        <CheckBox x:Name="ApplyAllCheck" Grid.Row="9"
                  Content="{l:L Error_ApplyToAll}"
                  FontSize="12" Foreground="{StaticResource Theme_TextSecondary}"
                  HorizontalAlignment="Center"/>
    </Grid>
</Window>
