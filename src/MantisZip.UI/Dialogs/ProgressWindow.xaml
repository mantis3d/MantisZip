<Window x:Class="MantisZip.UI.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:l="clr-namespace:MantisZip.UI.Localization"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:converters="clr-namespace:MantisZip.UI.Converters"
        Title="{l:L Progress_Title}" Height="Auto" Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{StaticResource Theme_WindowBg}">
    <Window.Resources>
        <converters:BatchStatusToIconConverter x:Key="BatchStatusIconConverter"/>
        <converters:ProgressStatusToBackgroundConverter x:Key="ProgressStatusBackgroundConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: 文件列表 -->
            <RowDefinition Height="Auto"/>  <!-- 1: 密码匹配区 -->
            <RowDefinition Height="Auto"/>  <!-- 2: 当前文件名 -->
            <RowDefinition Height="Auto"/>  <!-- 3: 文件进度条 -->
            <RowDefinition Height="Auto"/>  <!-- 4: 总体进度条 -->
            <RowDefinition Height="Auto"/>  <!-- 5: 文件计数 -->
            <RowDefinition Height="*"/>      <!-- 6: 弹性填充（吸收 MinHeight 多余空间，把按钮压到底部） -->
            <RowDefinition Height="Auto"/>  <!-- 7: 按钮 -->
        </Grid.RowDefinitions>

        <!-- ═══ 密码匹配区（默认隐藏，仅在尝试密码规则时显示）═══ -->
        <Border x:Name="PasswordSection" Grid.Row="1"
                Background="{StaticResource Theme_StatusWarning}" BorderBrush="{StaticResource Theme_StatusWarning}" BorderThickness="1"
                CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 第 1 行：图标 + 密码文本 + 按钮 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🔑" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="PwdMatchText" Grid.Column="1"
                               Text="" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Theme_TextPrimary}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Button x:Name="PwdRevealBtn" Grid.Column="2"
                            Width="24" Height="22" Margin="4,0,0,0"
                            Content="👁" FontSize="10" Padding="0"
                            Background="{StaticResource Theme_ButtonBg}" BorderThickness="1"
                            BorderBrush="{StaticResource Theme_Border}" Foreground="{StaticResource Theme_TextSecondary}"
                            Cursor="Hand" ToolTip="{l:L PwdMgr_Col_Password}"
                            Click="PwdRevealBtn_Click"
                            IsEnabled="False"/>

                    <Button x:Name="PwdCopyBtn" Grid.Column="3"
                            Width="24" Height="22" Margin="4,0,0,0"
                            Content="📋" FontSize="12" Padding="0"
                            Background="{StaticResource Theme_ButtonBg}" BorderThickness="1"
                            BorderBrush="{StaticResource Theme_Border}" Foreground="{StaticResource Theme_TextSecondary}"
                            Cursor="Hand" ToolTip="{l:L PwdMgr_Col_Password}"
                            Click="PwdCopyBtn_Click"
                            IsEnabled="False"/>
                </Grid>

                <!-- 第 2 行：规则描述 -->
                <TextBlock x:Name="PwdRuleText" Grid.Row="1"
                           Text="" FontSize="12" Foreground="{StaticResource Theme_TextDisabled}"
                           Margin="22,2,0,0"/>

                <!-- 第 3 行：状态（验证通过 / 正在尝试） -->
                <TextBlock x:Name="PwdStatusText" Grid.Row="2"
                           Text="" FontSize="12" Foreground="{StaticResource Theme_TextDisabled}"
                           Margin="22,2,0,0"/>
            </Grid>
        </Border>

        <!-- 当前操作的文件名 -->
        <TextBlock x:Name="FileNameText" Grid.Row="2"
                   Text="{l:L Progress_Processing}"
                   TextTrimming="CharacterEllipsis"
                   Foreground="{StaticResource Theme_TextPrimary}"/>

        <!-- 当前文件进度条（上面） -->
        <Grid Grid.Row="3" Margin="0,6,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="FileProgressBar" Grid.Column="0"
                         Height="14"
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="{StaticResource Theme_ProgressFill}" Background="{StaticResource Theme_ProgressBg}"/>
            <TextBlock x:Name="FilePercentText" Grid.Column="1"
                       Text=""
                       Width="42" Margin="6,0,0,0"
                       HorizontalAlignment="Right"
                       Foreground="{StaticResource Theme_TextSecondary}" FontSize="12"/>
        </Grid>

        <!-- 总体进度条（下面） -->
        <Grid Grid.Row="4" Margin="0,4,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="TotalProgressBar" Grid.Column="0"
                         Height="22"
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="{StaticResource Theme_ProgressFill}"/>
            <TextBlock x:Name="PercentText" Grid.Column="1"
                       Text="0%"
                       Width="42" Margin="6,0,0,0"
                       HorizontalAlignment="Right"
                        FontWeight="Bold" Foreground="{StaticResource Theme_TextPrimary}"/>
        </Grid>

        <!-- 文件计数（始终显示，记录处理的压缩包数量） -->
        <TextBlock x:Name="FileCountText" Grid.Row="5"
                   Text=""
                   FontSize="12" Foreground="{StaticResource Theme_TextDisabled}"
                   Margin="0,0,0,4"/>

        <!-- ═══ 批处理文件列表（3 列：状态图标 | 文件名+进度条背景 | 百分比）═══ -->
        <ListView x:Name="BatchFileList" Grid.Row="0"
                  Visibility="Collapsed"
                  MaxHeight="160" Margin="0,0,0,8"
                  BorderThickness="1"
                  BorderBrush="{StaticResource Theme_Border}"
                  Background="{StaticResource Theme_WindowBg}"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  SelectionMode="Single"
                  HorizontalContentAlignment="Stretch">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <!-- 第 1 列: 状态图标（使用 Emoji.Wpf 实现彩色渲染） -->
                        <emoji:TextBlock Grid.Column="0"
                                         Text="{Binding Status, Converter={StaticResource BatchStatusIconConverter}}"
                                         FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                        <!-- 第 2 列: 文件名 + 进度条背景 -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Theme_TextPrimary}"
                                   Padding="4,2">
                            <TextBlock.Background>
                                <MultiBinding Converter="{StaticResource ProgressStatusBackgroundConverter}">
                                    <Binding Path="Progress"/>
                                    <Binding Path="Status"/>
                                </MultiBinding>
                            </TextBlock.Background>
                        </TextBlock>

                        <!-- 第 3 列: 进度百分比 -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Progress, StringFormat=\{0:F0\}%}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Theme_TextSecondary}"
                                   FontSize="11"
                                   Padding="0,0,6,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 底部按钮行 -->
        <Grid Grid.Row="7" Margin="0,4,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ToggleButton x:Name="KeepOpenToggle" Grid.Column="0"
                          Height="28" Width="34"
                          ToolTip="{l:L Progress_KeepOpen}"
                          VerticalAlignment="Center" Margin="0,0,4,0"
                          Background="{StaticResource Theme_ButtonBg}"
                          BorderBrush="{StaticResource Theme_Border}" BorderThickness="1"
                          Checked="KeepOpenToggle_Checked" Unchecked="KeepOpenToggle_Unchecked">
                <emoji:TextBlock Text="📌" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ToggleButton>
            <Button x:Name="PauseButton" Grid.Column="2"
                    Content="{l:L Progress_Button_Pause}" Width="80" Height="32" Margin="0,0,8,0"
                    Click="PauseButton_Click"
                    Background="{StaticResource Theme_ButtonBg}" BorderBrush="{StaticResource Theme_Border}" BorderThickness="1"/>
            <Button x:Name="CancelButton" Grid.Column="3"
                    Content="{l:L MsgBox_Cancel}" Width="80" Height="32"
                    Click="CancelButton_Click"
                    Background="{StaticResource Theme_ButtonBg}" BorderBrush="{StaticResource Theme_Border}" BorderThickness="1"/>
        </Grid>
    </Grid>
</Window>
