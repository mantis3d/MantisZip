<Window x:Class="MantisZip.UI.CompressSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L Compress_Title}" Height="640" Width="530"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme_WindowBg}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TabControl -->
        <TabControl Grid.Row="0" SelectionChanged="TabControl_SelectionChanged"
                     Background="{StaticResource Theme_WindowBg}"
                     BorderBrush="{StaticResource Theme_Border}"
                     Foreground="{StaticResource Theme_TextPrimary}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="MinHeight" Value="30"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="Background" Value="{StaticResource Theme_HeaderBg}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter Content="{TemplateBinding Header}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource Theme_WindowBg}"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Theme_Accent}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource Theme_ButtonHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <!-- ============ 通用 ============ -->
            <TabItem Header="{l:L Compress_Tab_General}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_WindowBg}">
                    <StackPanel>
                        <!-- 1. 源文件/目录 -->
                        <GroupBox Header="{l:L Compress_Source_Group}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="100"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,5">
                                    <Button x:Name="AddFileButton" Content="{l:L Compress_AddFile}" Width="80" Height="24" Click="AddFileButton_Click" Margin="0,0,5,0"/>
                                    <Button x:Name="AddFolderButton" Content="{l:L Compress_AddFolder}" Width="80" Height="24" Click="AddFolderButton_Click" Margin="0,0,5,0"/>
                                    <Button x:Name="RemoveButton" Content="{l:L Compress_Remove}" Width="60" Height="24" Click="RemoveButton_Click"/>
                                </StackPanel>

                                <ListBox x:Name="SourceListBox" Grid.Row="1" Margin="0,5,0,5">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </GroupBox>

                        <!-- 2. 压缩包设置 -->
                        <GroupBox Header="{l:L Compress_Archive_Group}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Row 0: Output mode radios -->
                                <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="输出方式:" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Vertical">
                                        <RadioButton x:Name="ManualRadio" GroupName="OutputMode" IsChecked="True" Checked="OutputMode_Changed"
                                                     Content="{l:L Compress_OutputMode_Manual}"/>
                                        <RadioButton x:Name="SeparateRadio" GroupName="OutputMode" Checked="OutputMode_Changed"
                                                     Content="{l:L Compress_OutputMode_Separate}"/>
                                        <RadioButton x:Name="CombinedRadio" GroupName="OutputMode" Checked="OutputMode_Changed"
                                                     Content="{l:L Compress_OutputMode_Combined}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 1: Output path -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:L Compress_OutputPath}" VerticalAlignment="Center"/>
                                <Grid Grid.Row="1" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="OutputPathTextBox" Grid.Column="0" Height="24" TextChanged="OutputPathTextBox_TextChanged"/>
                                    <Button x:Name="BrowseOutputButton" Content="{l:L Settings_Advanced_Browse}" Width="60" Height="24" Grid.Column="1" Click="BrowseOutputButton_Click"/>
                                </Grid>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{l:L Compress_Format}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <ComboBox x:Name="FormatComboBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,10,0,0" SelectedIndex="0" SelectionChanged="FormatComboBox_SelectionChanged">
                                    <ComboBoxItem Content="ZIP (.zip)" Tag="zip"/>
                                    <ComboBoxItem Content="7z (.7z)" Tag="7z"/>
                                    <ComboBoxItem Content="TAR.GZ (.tar.gz)" Tag="tar.gz"/>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{l:L Compress_Level}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <ComboBox x:Name="LevelCombo" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,10,0,0" SelectedIndex="2">
                                    <ComboBoxItem Tag="0" Content="{l:L Compress_Level_Store}"/>
                                    <ComboBoxItem Tag="3" Content="{l:L Compress_Level_Fast}"/>
                                    <ComboBoxItem Tag="5" Content="{l:L Compress_Level_Normal}"/>
                                    <ComboBoxItem Tag="9" Content="{l:L Compress_Level_Max}"/>
                                </ComboBox>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{l:L Compress_VolumeSize}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <ComboBox x:Name="SplitSizeCombo" Width="130" Height="24" SelectedIndex="0"
                                              SelectionChanged="SplitSizeCombo_SelectionChanged">
                                        <ComboBoxItem Tag="0" Content="{l:L Compress_Volume_None}"/>
                                        <ComboBoxItem Tag="1048576">1 MB</ComboBoxItem>
                                        <ComboBoxItem Tag="10485760">10 MB</ComboBoxItem>
                                        <ComboBoxItem Tag="52428800">50 MB</ComboBoxItem>
                                        <ComboBoxItem Tag="104857600">100 MB</ComboBoxItem>
                                        <ComboBoxItem Tag="681574400">650 MB (CD)</ComboBoxItem>
                                        <ComboBoxItem Tag="4294967296">4 GB (FAT32)</ComboBoxItem>
                                        <ComboBoxItem Tag="-1" Content="{l:L Compress_Volume_Custom}"/>
                                    </ComboBox>
                                    <TextBox x:Name="CustomSplitSizeBox" Width="80" Height="24" Margin="6,0,0,0"
                                             IsEnabled="False" Visibility="Collapsed"/>
                                    <TextBlock x:Name="CustomSplitUnit" Text="MB" VerticalAlignment="Center" Margin="4,0,0,0"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- 3. 加密（已移入加密 Tab 中） -->
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ 加密 ============ -->
            <TabItem x:Name="PasswordTab" Header="{l:L Compress_Tab_Password}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_WindowBg}">
                    <StackPanel Margin="10">
                        <!-- 启用加密开关 + 格式提示 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="EncryptCheckBox" Content="{l:L Compress_Encrypt_Check}" 
                                      Checked="EncryptCheckBox_Changed" Unchecked="EncryptCheckBox_Changed"
                                      FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock x:Name="PwdFormatHint"
                                       Text="{l:L Compress_Pwd_Zip7zOnly}"
                                       Foreground="{StaticResource Theme_TextDisabled}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>

                        <Grid x:Name="PasswordContentGrid" IsEnabled="False">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 从密码库选择 -->
                            <GroupBox x:Name="PwdLibraryGroup" Grid.Row="0" Margin="0,0,0,8"
                                      BorderBrush="{StaticResource Theme_Border}"
                                      BorderThickness="1">
                                <GroupBox.Header>
                                    <RadioButton x:Name="LibraryRadio" GroupName="PasswordSource" IsChecked="True"
                                                 Checked="PasswordSource_Changed"
                                                 Content="{l:L Compress_Pwd_FromLibrary}"
                                                 FontWeight="SemiBold"/>
                                 </GroupBox.Header>
                                <StackPanel x:Name="PwdLibraryContent">
                                    <TextBox x:Name="PwdSearchBox" Height="24"
                                             Text="{l:L Compress_Pwd_Search}"
                                             GotFocus="PwdSearchBox_GotFocus"
                                             TextChanged="PwdSearchBox_TextChanged"
                                             Margin="0,4,0,4"/>
                                    <ListBox x:Name="PwdLibraryList" Height="120"
                                             SelectionChanged="PwdLibraryList_SelectionChanged"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Description}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding PatternsDisplay}"
                                                               Foreground="{StaticResource Theme_TextSecondary}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock x:Name="PwdSelectedStatus"
                                               Foreground="{StaticResource Theme_TextSecondary}"
                                               FontSize="12"
                                               Margin="0,4,0,0"
                                               Text="{l:L Compress_Pwd_NoEntry}"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- 输入新密码 -->
                            <GroupBox x:Name="NewPwdGroup" Grid.Row="1" Margin="0,0,0,8"
                                      BorderBrush="{StaticResource Theme_Border}"
                                      BorderThickness="1">
                                <GroupBox.Header>
                                    <RadioButton x:Name="NewPwdRadio" GroupName="PasswordSource"
                                                 Checked="PasswordSource_Changed"
                                                 Content="{l:L Compress_Pwd_EnterNew}"
                                                 FontWeight="SemiBold"/>
                                </GroupBox.Header>
                                <StackPanel x:Name="NewPwdContent">
                                     <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:L PwdEdit_PasswordLabel}" VerticalAlignment="Center"/>
                                        <Grid Grid.Row="0" Grid.Column="1">
                                            <PasswordBox x:Name="PasswordBox" Height="24" PasswordChanged="PasswordBox_PasswordChanged"/>
                                            <TextBox x:Name="PwdTextBox" Height="24" TextChanged="PwdTextBox_TextChanged" Visibility="Collapsed"/>
                                        </Grid>
                                        <Button x:Name="PwdRevealBtn" Grid.Row="0" Grid.Column="2" Width="28" Height="24" Margin="4,0,0,0"
                                                Content="👁" Click="PwdRevealBtn_Click"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:L Compress_Encrypt_Confirm}" VerticalAlignment="Center" Margin="0,5,0,0"/>
                                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,5,0,0">
                                            <PasswordBox x:Name="ConfirmPasswordBox" Height="24"/>
                                            <TextBox x:Name="ConfirmPwdTextBox" Height="24" Visibility="Collapsed"/>
                                        </Grid>

                                        <TextBlock x:Name="PwdStrengthText" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="4,5,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            <Separator Grid.Row="2" Margin="0,4,0,6"
                                       Background="{StaticResource Theme_BorderLight}"/>

                            <!-- 共享区域：保存到密码库 -->
                            <Border Grid.Row="3" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1" Padding="8" Margin="0,0,0,4"
                                    CornerRadius="4">
                                <StackPanel>
                                    <CheckBox x:Name="PwdSaveCheck" Content="{l:L Compress_Pwd_SaveToLibrary}" IsChecked="True" Margin="0,0,0,6"/>
                                     <Grid Margin="20,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:L Compress_Pwd_Description}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="PwdDescBox" Grid.Row="0" Grid.Column="1" Height="24"/>

                                        <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" Margin="0,4,0,0">
                                            <TextBlock Text="{l:L Compress_Pwd_Rules}"/>
                                            <CheckBox x:Name="PwdAutoRules" Content="{l:L Compress_Pwd_AutoRules}" IsChecked="True"
                                                      Margin="0,2,0,0"
                                                      Checked="PwdAutoRules_Changed" Unchecked="PwdAutoRules_Changed"/>
                                        </StackPanel>
                                        <TextBox x:Name="PwdRulesBox" Grid.Row="1" Grid.Column="1" Height="60"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 IsReadOnly="True"
                                                 Padding="4"
                                                 Background="{StaticResource Theme_SurfaceBg}"
                                                 Foreground="{StaticResource Theme_TextPrimary}"
                                                 BorderBrush="{StaticResource Theme_BorderLight}"
                                                 BorderThickness="1"/>
                                     </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ 注释 ============ -->
            <TabItem x:Name="CommentTab" Header="{l:L Compress_Tab_Comment}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_WindowBg}">
                    <StackPanel Margin="10">
                        <!-- 注释编辑框 -->
                        <TextBox x:Name="CommentTextBox"
                                 Height="340"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="8"
                                 Background="{StaticResource Theme_SurfaceBg}"
                                 Foreground="{StaticResource Theme_TextPrimary}"
                                 BorderBrush="{StaticResource Theme_Border}"
                                 BorderThickness="1"/>

                        <!-- 分配策略 -->
                        <GroupBox Header="{l:L Compress_Comment_Distribution}" Margin="0,12,0,0">
                            <StackPanel x:Name="CommentDistributionPanel">
                                <RadioButton x:Name="CommentAllSame" GroupName="CommentDistribution" IsChecked="True"
                                             Content="{l:L Compress_Comment_AllSame}" Margin="0,4"/>
                                <RadioButton x:Name="CommentFirstOnly" GroupName="CommentDistribution"
                                             Content="{l:L Compress_Comment_FirstOnly}" Margin="0,4"/>
                                <RadioButton x:Name="CommentPerLine" GroupName="CommentDistribution"
                                             Content="{l:L Compress_Comment_PerLine}" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ZIP-only 提示 -->
                        <TextBlock x:Name="CommentZipOnlyHint"
                                   Text="{l:L Compress_Comment_ZipOnly}"
                                   Foreground="{StaticResource Theme_TextDisabled}"
                                   FontSize="12"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 4. 按钮（始终在底部） -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CompressButton" Content="{l:L Shell_Compress}" Width="80" Height="28" Margin="5,0" Click="CompressButton_Click" IsEnabled="False"/>
            <Button x:Name="CancelButton" Content="{l:L MsgBox_Cancel}" Width="80" Height="28" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
