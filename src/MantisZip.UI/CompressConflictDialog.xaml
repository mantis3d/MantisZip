<Window x:Class="MantisZip.UI.CompressConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="目标文件已存在" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="13" Foreground="#333" TextWrapping="Wrap">
            目标文件 <Run x:Name="FileNameText" FontFamily="Consolas" FontWeight="SemiBold"/> 已存在，请选择处理方式：
        </TextBlock>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="OverwriteBtn" Content="覆盖" Width="85" Height="28" Click="Overwrite_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,6,0"/>
            <Button x:Name="AddBtn" Content="添加到压缩包" Width="110" Height="28" Click="Add_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="6,0,6,0"/>
            <Button x:Name="RenameBtn" Content="自动重命名" Width="90" Height="28" Click="Rename_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="6,0,6,0"/>
            <Button Content="取消" Width="70" Height="28" Click="Cancel_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="6,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
