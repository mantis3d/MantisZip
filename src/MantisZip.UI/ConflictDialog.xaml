<Window x:Class="MantisZip.UI.ConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文件冲突" Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <TextBlock Grid.Row="0" FontSize="13" FontWeight="SemiBold" Foreground="#333">
            文件 <Run x:Name="FileNameText" FontFamily="Consolas"/> 冲突
        </TextBlock>

        <!-- Row 2: Comparison panel -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="磁盘已有" FontWeight="SemiBold" FontSize="12" Foreground="#555" Margin="0,0,0,6"/>
                    <TextBlock FontSize="11" Foreground="#333" LineHeight="18">
                        <Run Text="大小: "/><Run x:Name="ExistingSizeText" Foreground="#888"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#333" LineHeight="18">
                        <Run Text="修改: "/><Run x:Name="ExistingDateText" Foreground="#888"/>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="1" Background="#FFE082" CornerRadius="10"
                        Width="32" Height="22" Margin="12,10"
                        HorizontalAlignment="Center" VerticalAlignment="Top">
                    <TextBlock Text="VS" FontSize="10" FontWeight="Bold" Foreground="#333"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="压缩包内" FontWeight="SemiBold" FontSize="12" Foreground="#555" Margin="0,0,0,6"/>
                    <TextBlock FontSize="11" Foreground="#333" LineHeight="18">
                        <Run Text="大小: "/><Run x:Name="EntrySizeText" Foreground="#2196F3" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#333" LineHeight="18">
                        <Run Text="修改: "/><Run x:Name="EntryDateText" Foreground="#2196F3" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 4: Comparison result -->
        <TextBlock x:Name="CompareResultText" Grid.Row="4" FontSize="11" Foreground="#555"
                   TextWrapping="Wrap" HorizontalAlignment="Center"/>

        <!-- Row 6: Buttons -->
        <WrapPanel Grid.Row="6" HorizontalAlignment="Center">
            <Button Content="覆盖" Width="75" Height="28" Click="Overwrite_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,4,4"/>
            <Button Content="覆盖较旧" Width="75" Height="28" Click="OverwriteIfOlder_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="4,0,4,4"/>
            <Button Content="覆盖较小" Width="75" Height="28" Click="OverwriteIfSmaller_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="4,0,4,4"/>
            <Button Content="重命名" Width="75" Height="28" Click="Rename_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="4,0,4,4"/>
            <Button Content="跳过" Width="75" Height="28" Click="Skip_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="4,0,0,4"/>
        </WrapPanel>

        <!-- Row 8: Checkbox -->
        <CheckBox x:Name="ApplyAllCheck" Grid.Row="8"
                  Content="对后续所有文件使用相同操作"
                  FontSize="12" Foreground="#555"
                  HorizontalAlignment="Center"/>
    </Grid>
</Window>
