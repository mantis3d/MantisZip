<Window x:Class="MantisZip.UI.ConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文件冲突" Height="180" Width="380"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,14" FontSize="13" Foreground="#333">
            <Run FontWeight="SemiBold">文件</Run>
            <Run x:Name="FileNameText" FontWeight="SemiBold" FontFamily="Consolas"/>
            <Run>已存在，请选择处理方式：</Run>
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
            <Button Content="覆盖" Width="70" Height="28" Click="Overwrite_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,6,0"/>
            <Button Content="重命名" Width="70" Height="28" Click="Rename_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="6,0,6,0"/>
            <Button Content="跳过" Width="70" Height="28" Click="Skip_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="6,0,0,0"/>
        </StackPanel>

        <CheckBox x:Name="ApplyAllCheck" Grid.Row="2"
                  Content="对后续所有文件使用相同操作"
                  FontSize="12" Foreground="#555"
                  HorizontalAlignment="Center"/>
    </Grid>
</Window>
