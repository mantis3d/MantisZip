<Window x:Class="MantisZip.UI.ExtractSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L ExtractSettings_Title}" Height="520" Width="530"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme_WindowBg}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TabControl -->
        <TabControl Grid.Row="0" SelectionChanged="TabControl_SelectionChanged"
                     Background="{StaticResource Theme_WindowBg}"
                     BorderBrush="{StaticResource Theme_Border}"
                     Foreground="{StaticResource Theme_TextPrimary}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="MinHeight" Value="30"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="Background" Value="{StaticResource Theme_HeaderBg}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter Content="{TemplateBinding Header}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource Theme_WindowBg}"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Theme_Accent}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource Theme_ButtonHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ============ 基本 ============ -->
            <TabItem Header="{l:L ExtractSettings_Tab_Basic}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_WindowBg}">
                    <StackPanel>
                        <!-- 1. 源文件 -->
                        <GroupBox Header="{l:L ExtractSettings_Source_Group}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="140"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="FileCountText" Grid.Row="0"
                                           Margin="0,0,0,6"/>
                                <ListBox x:Name="FileListBox" Grid.Row="1"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       ToolTip="{Binding}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </GroupBox>

                        <!-- 2. 解压选项 -->
                        <GroupBox Header="{l:L ExtractSettings_Options_Group}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Row 0: 输出方式 -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{l:L ExtractSettings_ModeLabel}"
                                           VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                    <RadioButton x:Name="ManualRadio" GroupName="OutputMode"
                                                 Checked="OutputMode_Changed"
                                                 Content="{l:L ExtractSettings_Mode_Manual}"/>
                                    <RadioButton x:Name="HereRadio" GroupName="OutputMode"
                                                 Checked="OutputMode_Changed"
                                                 Content="{l:L ExtractSettings_Mode_Here}"/>
                                    <RadioButton x:Name="SmartRadio" GroupName="OutputMode"
                                                 Checked="OutputMode_Changed"
                                                 Content="{l:L ExtractSettings_Mode_Smart}"/>
                                    <RadioButton x:Name="ToNameRadio" GroupName="OutputMode" IsChecked="True"
                                                 Checked="OutputMode_Changed"
                                                 Content="{l:L ExtractSettings_Mode_ToName}"/>
                                </StackPanel>

                                <!-- Row 1: 输出路径（始终可见，启用/禁用切换） -->
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{l:L ExtractSettings_OutputPath}"
                                           VerticalAlignment="Center"/>
                                <Grid Grid.Row="1" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ManualPathTextBox" Grid.Column="0"
                                             Height="24"
                                             TextChanged="ManualPathTextBox_TextChanged"/>
                                    <Button x:Name="BrowseButton" Grid.Column="1"
                                            Content="{l:L Settings_Advanced_Browse}"
                                            Width="60" Height="24" Margin="6,0,0,0"
                                            Click="BrowseButton_Click"/>
                                </Grid>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ 高级 ============ -->
            <TabItem Header="{l:L ExtractSettings_Tab_Advanced}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_WindowBg}">
                    <StackPanel>
                        <GroupBox Header="{l:L ExtractSettings_Behavior_Group}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{l:L ExtractSettings_ConflictLabel}"
                                           VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                    <RadioButton x:Name="ConflictAskRadio" GroupName="ConflictAction"
                                                 Content="{l:L Settings_Extract_Conflict_Ask}"/>
                                    <RadioButton x:Name="ConflictOverwriteRadio" GroupName="ConflictAction"
                                                 Content="{l:L CompressConflict_Overwrite}"/>
                                    <RadioButton x:Name="ConflictRenameRadio" GroupName="ConflictAction"
                                                 Content="{l:L CompressConflict_Rename}"/>
                                    <RadioButton x:Name="ConflictSkipRadio" GroupName="ConflictAction"
                                                 Content="{l:L Settings_Extract_Conflict_Skip}"/>
                                </StackPanel>

                                <CheckBox x:Name="OpenFolderCheck" Grid.Row="1" Grid.Column="1"
                                          Content="{l:L Settings_Extract_OpenFolderAfter}"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 按钮（始终在底部） -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ExtractButton" Content="{l:L ExtractSettings_Extract}" Width="80" Height="28" Margin="5,0" Click="ExtractButton_Click" IsDefault="True"/>
            <Button Content="{l:L ExtractSettings_Cancel}" Width="80" Height="28" Margin="5,0" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
