<Window x:Class="MantisZip.UI.ExtractSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L ExtractSettings_Title}" Width="480" SizeToContent="Height" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme_WindowBg}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <TextBlock Grid.Row="0" Text="{l:L ExtractSettings_Title}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource Theme_TextPrimary}"
                   Margin="0,0,0,8"/>

        <!-- Row 1: File count -->
        <TextBlock x:Name="FileCountText" Grid.Row="1"
                   Foreground="{StaticResource Theme_TextPrimary}"
                   Margin="0,0,0,6"/>

        <!-- Row 2: File list (read-only, scrollable) -->
        <ListBox x:Name="FileListBox" Grid.Row="2"
                 MaxHeight="200"
                 BorderBrush="{StaticResource Theme_Border}"
                 Background="{StaticResource Theme_WindowBg}"
                 Foreground="{StaticResource Theme_TextPrimary}"
                 Margin="0,0,0,10"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}"
                               ToolTip="{Binding}"
                               Foreground="{StaticResource Theme_TextPrimary}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Row 3: Separator -->
        <Separator Grid.Row="3"
                   Background="{StaticResource Theme_Border}"
                   Margin="0,0,0,10"/>

        <!-- Row 4: Output mode label -->
        <TextBlock Grid.Row="4"
                   Text="{l:L ExtractSettings_ModePreview}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Theme_TextPrimary}"
                   Margin="0,0,0,6"/>

        <!-- Row 5: Mode radio buttons -->
        <StackPanel Grid.Row="5" Margin="0,0,0,8">
            <RadioButton x:Name="ManualRadio" GroupName="OutputMode"
                         Checked="OutputMode_Changed"
                         Foreground="{StaticResource Theme_TextPrimary}"
                         Content="{l:L ExtractSettings_Mode_Manual}"/>
            <RadioButton x:Name="HereRadio" GroupName="OutputMode"
                         Checked="OutputMode_Changed"
                         Foreground="{StaticResource Theme_TextPrimary}"
                         Content="{l:L ExtractSettings_Mode_Here}"/>
            <RadioButton x:Name="SmartRadio" GroupName="OutputMode"
                         Checked="OutputMode_Changed"
                         Foreground="{StaticResource Theme_TextPrimary}"
                         Content="{l:L ExtractSettings_Mode_Smart}"/>
            <RadioButton x:Name="ToNameRadio" GroupName="OutputMode"
                         Checked="OutputMode_Changed"
                         Foreground="{StaticResource Theme_TextPrimary}"
                         Content="{l:L ExtractSettings_Mode_ToName}"/>
        </StackPanel>

        <!-- Row 6: Path selection area -->
        <Grid Grid.Row="6" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Manual input: TextBox + Browse button -->
            <Grid Grid.Row="0" x:Name="ManualPathRow" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ManualPathTextBox" Grid.Column="0"
                         Height="26"
                         TextChanged="ManualPathTextBox_TextChanged"
                         Foreground="{StaticResource Theme_TextPrimary}"
                         Background="{StaticResource Theme_WindowBg}"
                         BorderBrush="{StaticResource Theme_Border}"/>
                <Button x:Name="BrowseButton" Grid.Column="1"
                        Content="{l:L ExtractSettings_Browse}"
                        Width="70" Height="26" Margin="6,0,0,0"
                        Click="BrowseButton_Click"
                        Background="{StaticResource Theme_HeaderBg}"
                        Foreground="{StaticResource Theme_TextPrimary}"
                        BorderBrush="{StaticResource Theme_Border}"/>
            </Grid>

            <!-- Preview text for non-manual modes -->
            <TextBlock x:Name="ModePreviewText" Grid.Row="1"
                       Visibility="Collapsed"
                       Foreground="{StaticResource Theme_TextPrimary}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </Grid>

        <!-- Row 7: Bottom buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{l:L ExtractSettings_Cancel}"
                    Width="80" Height="30" Margin="0,0,8,0"
                    IsCancel="True"
                    Click="CancelButton_Click"
                    Background="{StaticResource Theme_HeaderBg}"
                    Foreground="{StaticResource Theme_TextPrimary}"
                    BorderBrush="{StaticResource Theme_Border}"/>
            <Button x:Name="ExtractButton"
                    Content="{l:L ExtractSettings_Extract}"
                    Width="80" Height="30"
                    IsDefault="True"
                    Click="ExtractButton_Click"
                    Background="{StaticResource Theme_Accent}"
                    Foreground="White"
                    BorderBrush="{StaticResource Theme_Accent}"/>
        </StackPanel>
    </Grid>
</Window>
