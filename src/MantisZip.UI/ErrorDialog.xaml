<Window x:Class="MantisZip.UI.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L Error_Title}" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>

        <TextBlock x:Name="ErrorMsgText" Grid.Row="2" TextWrapping="Wrap" FontSize="11" Foreground="#888"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="{l:L Error_Retry}" Width="72" Height="28" Click="Retry_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,6,0"/>
            <Button Content="{l:L Error_Skip}" Width="72" Height="28" Click="Skip_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="6,0,6,0"/>
            <Button Content="{l:L Error_Abort}" Width="72" Height="28" Click="Abort_Click"
                    Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="6,0,0,0"/>
        </StackPanel>

        <CheckBox x:Name="ApplyAllCheck" Grid.Row="6"
                  Content="{l:L Error_ApplyToAll}"
                  FontSize="12" Foreground="#555"
                  HorizontalAlignment="Center"/>
    </Grid>
</Window>
