<Window x:Class="MantisZip.UI.LogPrivacyHelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L Settings_Debug_LogPrivacyHelp_Title}" Height="460" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Theme_WindowBg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- 简介 -->
            <TextBlock Text="{l:L Settings_Debug_LogPrivacyHelp_Title}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="{l:L Settings_Debug_LogPrivacyHelp_Intro}" TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="22"/>

            <!-- 三种模式说明 -->
            <Border Background="{StaticResource Theme_SurfaceBg}" CornerRadius="4" Padding="14" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{l:L Settings_Debug_LogPrivacyHelp_Mode_Off}" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="20"/>
                    <TextBlock Text="{l:L Settings_Debug_LogPrivacyHelp_Mode_Filename}" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="20"/>
                    <TextBlock Text="{l:L Settings_Debug_LogPrivacyHelp_Mode_Extension}" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="20"/>
                    <TextBlock Text="{l:L Settings_Debug_LogPrivacyHelp_Mode_Full}" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>

            <!-- 影响范围 -->
            <TextBlock Text="{l:L Settings_Debug_LogPrivacyHelp_What}" TextWrapping="Wrap" Margin="0,0,0,8" LineHeight="22"/>
            <TextBlock Text="{l:L Settings_Debug_LogPrivacyHelp_WhatNot}" TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="22"/>

            <!-- 关闭按钮 -->
            <Button Content="{l:L Settings_Debug_LogPrivacyHelp_Close}" Click="Close_Click" Width="100" Height="32"
                    HorizontalAlignment="Right" IsDefault="True"
                    Background="{StaticResource Theme_Accent}" Foreground="{StaticResource Theme_TextOnAccent}" Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>
</Window>
