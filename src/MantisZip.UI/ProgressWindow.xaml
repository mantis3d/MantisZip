<Window x:Class="MantisZip.UI.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作进度" Height="175" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 当前操作的文件名 -->
        <TextBlock x:Name="FileNameText" Grid.Row="0"
                   Text="正在处理..."
                   TextTrimming="CharacterEllipsis"
                   Foreground="#333"/>

        <!-- 当前文件进度条（上面） -->
        <Grid Grid.Row="1" Margin="0,6,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="FileProgressBar" Grid.Column="0"
                         Height="10"
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="#2196F3" Background="#E0E0E0"/>
            <TextBlock x:Name="FilePercentText" Grid.Column="1"
                       Text=""
                       Width="42" Margin="6,0,0,0"
                       HorizontalAlignment="Right"
                       Foreground="#666" FontSize="11"/>
        </Grid>

        <!-- 总体进度条（下面） -->
        <Grid Grid.Row="2" Margin="0,4,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="TotalProgressBar" Grid.Column="0"
                         Height="18"
                         Minimum="0" Maximum="100" Value="0"/>
            <TextBlock x:Name="PercentText" Grid.Column="1"
                       Text="0%"
                       Width="42" Margin="6,0,0,0"
                       HorizontalAlignment="Right"
                       FontWeight="Bold" Foreground="#333"/>
        </Grid>

        <!-- 取消按钮 -->
        <Button x:Name="CancelButton" Grid.Row="4"
                Content="取消" Width="80" Height="28"
                HorizontalAlignment="Right"
                Click="CancelButton_Click"/>
    </Grid>
</Window>
