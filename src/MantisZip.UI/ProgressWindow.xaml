<Window x:Class="MantisZip.UI.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作进度" Height="150" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 当前操作的文件名 -->
        <TextBlock x:Name="FileNameText" Grid.Row="0" 
                   Text="正在处理..." 
                   TextTrimming="CharacterEllipsis"
                   Foreground="#333"/>

        <!-- 进度条 -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <ProgressBar x:Name="ProgressBar" 
                         Height="20"
                         Minimum="0" Maximum="100" Value="0"/>
            <TextBlock x:Name="PercentText" 
                       Text="0%" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="#333"/>
        </Grid>

        <!-- 百分比和状态 -->
        <Grid Grid.Row="2">
            <TextBlock x:Name="StatusText" Text="正在处理" 
                       HorizontalAlignment="Right" Foreground="#666"/>
        </Grid>

        <!-- 取消按钮 -->
        <Button x:Name="CancelButton" Grid.Row="3" 
                Content="取消" Width="80" Height="28"
                HorizontalAlignment="Right"
                Click="CancelButton_Click"/>
    </Grid>
</Window>