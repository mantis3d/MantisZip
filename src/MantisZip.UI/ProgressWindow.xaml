<Window x:Class="MantisZip.UI.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作进度" Height="Auto" Width="400" MinHeight="175"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 密码匹配区（默认隐藏，仅在尝试密码规则时显示）═══ -->
        <Border x:Name="PasswordSection" Grid.Row="0"
                Background="#FFF8E1" BorderBrush="#FFE082" BorderThickness="1"
                CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 第 1 行：图标 + 密码文本 + 按钮 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🔑" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="PwdMatchText" Grid.Column="1"
                               Text="" FontSize="13" FontWeight="SemiBold"
                               Foreground="#333" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Button x:Name="PwdRevealBtn" Grid.Column="2"
                            Width="24" Height="22" Margin="4,0,0,0"
                            Content="👁" FontSize="10" Padding="0"
                            Background="White" BorderThickness="1"
                            BorderBrush="#CCC" Foreground="#555"
                            Cursor="Hand" ToolTip="显示/隐藏密码"
                            Click="PwdRevealBtn_Click"
                            IsEnabled="False"/>

                    <Button x:Name="PwdCopyBtn" Grid.Column="3"
                            Width="24" Height="22" Margin="4,0,0,0"
                            Content="📋" FontSize="10" Padding="0"
                            Background="White" BorderThickness="1"
                            BorderBrush="#CCC" Foreground="#555"
                            Cursor="Hand" ToolTip="复制密码"
                            Click="PwdCopyBtn_Click"
                            IsEnabled="False"/>
                </Grid>

                <!-- 第 2 行：规则描述 -->
                <TextBlock x:Name="PwdRuleText" Grid.Row="1"
                           Text="" FontSize="11" Foreground="#888"
                           Margin="22,2,0,0"/>

                <!-- 第 3 行：状态（验证通过 / 正在尝试） -->
                <TextBlock x:Name="PwdStatusText" Grid.Row="2"
                           Text="" FontSize="11" Foreground="#888"
                           Margin="22,2,0,0"/>
            </Grid>
        </Border>

        <!-- 当前操作的文件名 -->
        <TextBlock x:Name="FileNameText" Grid.Row="1"
                   Text="正在处理..."
                   TextTrimming="CharacterEllipsis"
                   Foreground="#333"/>

        <!-- 当前文件进度条（上面） -->
        <Grid Grid.Row="2" Margin="0,6,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="FileProgressBar" Grid.Column="0"
                         Height="10"
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="#2196F3" Background="#E0E0E0"/>
            <TextBlock x:Name="FilePercentText" Grid.Column="1"
                       Text=""
                       Width="42" Margin="6,0,0,0"
                       HorizontalAlignment="Right"
                       Foreground="#666" FontSize="11"/>
        </Grid>

        <!-- 总体进度条（下面） -->
        <Grid Grid.Row="3" Margin="0,4,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="TotalProgressBar" Grid.Column="0"
                         Height="18"
                         Minimum="0" Maximum="100" Value="0"/>
            <TextBlock x:Name="PercentText" Grid.Column="1"
                       Text="0%"
                       Width="42" Margin="6,0,0,0"
                       HorizontalAlignment="Right"
                       FontWeight="Bold" Foreground="#333"/>
        </Grid>

        <!-- 取消按钮 -->
        <Button x:Name="CancelButton" Grid.Row="5"
                Content="取消" Width="80" Height="28"
                HorizontalAlignment="Right"
                Click="CancelButton_Click"/>
    </Grid>
</Window>
