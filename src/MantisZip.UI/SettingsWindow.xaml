<Window x:Class="MantisZip.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="500" Width="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabs -->
        <TabControl Grid.Row="0" x:Name="SettingsTabs">
            <!-- ═══════ 压缩 ═══════ -->
            <TabItem Header="压缩">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="默认压缩格式" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="DefaultFormatCombo" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="ZIP (.zip)" Tag="zip"/>
                            <ComboBoxItem Content="7z (.7z)" Tag="7z"/>
                            <ComboBoxItem Content="TAR.GZ (.tar.gz)" Tag="tar.gz"/>
                        </ComboBox>

                        <TextBlock Text="默认压缩级别" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <ComboBox x:Name="DefaultLevelCombo" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Tag="0">0 - 仅存储</ComboBoxItem>
                            <ComboBoxItem Tag="3">3 - 快速压缩</ComboBoxItem>
                            <ComboBoxItem Tag="5">5 - 正常压缩</ComboBoxItem>
                            <ComboBoxItem Tag="9">9 - 极限压缩</ComboBoxItem>
                        </ComboBox>

                        <CheckBox x:Name="CloseAfterCompressCheck" Content="压缩完成后关闭压缩窗口" Margin="0,16,0,0"/>
                        <CheckBox x:Name="KeepExtCheck" Content="保留源文件扩展名（abc.max → abc.max.zip）" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 解压 ═══════ -->
            <TabItem Header="解压">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="默认解压到" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ExtractDestCombo" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="每次询问" Tag="ask"/>
                            <ComboBoxItem Content="压缩包所在目录" Tag="same-dir"/>
                            <ComboBoxItem Content="桌面" Tag="desktop"/>
                        </ComboBox>

                        <TextBlock Text="文件已存在时" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <ComboBox x:Name="ConflictCombo" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="询问我" Tag="ask"/>
                            <ComboBoxItem Content="覆盖" Tag="overwrite"/>
                            <ComboBoxItem Content="自动重命名" Tag="rename"/>
                            <ComboBoxItem Content="跳过" Tag="skip"/>
                        </ComboBox>

                        <CheckBox x:Name="OpenFolderCheck" Content="解压后打开目标文件夹" Margin="0,16,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 上下文菜单 ═══════ -->
            <TabItem Header="上下文菜单">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="右键菜单项目" Padding="8" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox x:Name="EnableCompressCheck" Content="启用「压缩」菜单" Margin="0,4"/>
                                <CheckBox x:Name="EnableQuickCheck" Content="启用「压缩为（文件名）.zip」快速压缩菜单" Margin="0,4"/>
                                <CheckBox x:Name="EnableOpenCheck" Content="启用「打开压缩包」菜单（压缩包浏览）" Margin="0,4"/>
                                <CheckBox x:Name="EnableExtractCheck" Content="启用解压菜单（解压到此处 / 解压到压缩包名 / 解压到……）" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="显示方式" Padding="8" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox x:Name="CascadeCheck" Content="层叠上下文菜单（所有 MantisZip 项目归入一个子菜单）" Margin="0,4"/>
                                <CheckBox x:Name="ShowIconsCheck" Content="上下文菜单显示图标" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="状态" Padding="8">
                            <StackPanel>
                                <TextBlock x:Name="ShellStatusText" Text="检测中..." Margin="0,0,0,8" Foreground="#555"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="InstallBtn" Content="安装" Width="60" Height="26"
                                            Click="InstallBtn_Click" IsEnabled="False"/>
                                    <Button x:Name="UninstallBtn" Content="卸载" Width="60" Height="26" Margin="6,0,0,0"
                                            Click="UninstallBtn_Click" IsEnabled="False"/>
                                    <Button x:Name="ApplyShellBtn" Content="应用" Width="60" Height="26" Margin="6,0,0,0"
                                            Click="ApplyShellBtn_Click" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 预览 ═══════ -->
            <TabItem Header="预览">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="EnableImagePreviewCheck" Content="启用图片预览（jpg/png/gif/bmp/webp/ico）" Margin="0,4"/>
                        <CheckBox x:Name="EnableTextPreviewCheck" Content="启用文本预览（txt/log/code 等）" Margin="0,16,0,4"/>

                        <TextBlock Text="预览文件大小上限 (MB)" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="MaxPreviewSizeSlider" Width="250" Minimum="1" Maximum="500"
                                    Value="100" TickFrequency="10" IsSnapToTickEnabled="True"/>
                            <TextBlock x:Name="MaxPreviewSizeText" Text="100 MB" Width="60" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Foreground="#888" FontSize="11" Margin="0,4,0,0">
                            超过此大小的文件不会进行预览（包括图片和文本）。</TextBlock>

                        <TextBlock Text="预览面板位置" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <ComboBox x:Name="PreviewPositionCombo" Width="220" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <ComboBoxItem Tag="1" IsSelected="True">底部（当前默认）</ComboBoxItem>
                            <ComboBoxItem Tag="2">目录树下方</ComboBoxItem>
                            <ComboBoxItem Tag="3">文件列表下方</ComboBoxItem>
                            <ComboBoxItem Tag="4">文件列表右侧</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="信息面板方向" FontWeight="SemiBold" Margin="0,8,0,4"/>
                        <ComboBox x:Name="InfoPanelOrientationCombo" Width="180" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <ComboBoxItem Tag="Horizontal" IsSelected="True">内容右侧（左右）</ComboBoxItem>
                            <ComboBoxItem Tag="Vertical">内容下方（上下）</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="文本预览最大大小 (MB)" FontWeight="SemiBold" Margin="0,12,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="MaxTextSizeSlider" Width="200" Minimum="1" Maximum="50"
                                    Value="5" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock x:Name="MaxTextSizeText" Text="5 MB" Width="50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="文本预览字号" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="TextFontSizeSlider" Width="200" Minimum="8" Maximum="36"
                                    Value="12" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock x:Name="TextFontSizeText" Text="12" Width="30" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border BorderBrush="#CCC" BorderThickness="1" Padding="8" Margin="0,8,0,0"
                                Background="#F9F9F9" CornerRadius="4">
                            <TextBlock x:Name="TextFontSizeSample" FontSize="12"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       Text="示例文本 — The quick brown fox jumps over the lazy dog."
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 密码管理 ═══════ -->
            <TabItem Header="密码管理">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="ShowPasswordNotifCheck" Content="解压时在进度条窗口显示匹配到的密码规则和密码文本" Margin="0,4"/>
                        <TextBlock Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="24,0,0,12">
                            启用后，尝试保存的密码规则时进度条上方会显示规则名称和密码，
                            支持复制密码文本。禁用后不显示密码信息。</TextBlock>

                        <CheckBox x:Name="RevealPasswordCheck" Content="默认显示密码明文（不勾选则显示为 ******）" Margin="0,12,0,4"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 高级 ═══════ -->
            <TabItem Header="高级">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="7z 可执行文件路径" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SevenZipPathBox" Grid.Column="0" Height="24" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="浏览" Width="60" Height="24" Margin="6,0,0,0" Click="BrowseSevenZip_Click"/>
                        </Grid>

                        <Button Content="清理预览临时文件" Width="140" Height="26" Margin="0,20,0,0"
                                HorizontalAlignment="Left" Click="CleanTemp_Click"/>

                        <Separator Margin="0,20,0,10"/>

                        <TextBlock Text="关于 MantisZip" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="11">
                            <Run>版本: </Run><Run x:Name="AboutVersionText"/>
                            <LineBreak/>
                            <Run>.NET 9 WPF 桌面应用 ｜ 基于 SharpZipLib + SevenZipExtractor</Run>
                            <LineBreak/>
                            <Run>7-Zip 组件遵循 GNU LGPL 许可证</Run>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SaveBtn" Content="保存" Width="80" Height="28" Click="SaveBtn_Click"/>
            <Button Content="取消" Width="80" Height="28" Margin="8,0,0,0" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
