<Window x:Class="MantisZip.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="{l:L Settings_Title}" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource Theme_WindowBg}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabs -->
        <TabControl Grid.Row="0" x:Name="SettingsTabs" TabStripPlacement="Left"
                    Background="{StaticResource Theme_WindowBg}"
                    TextOptions.TextRenderingMode="Grayscale">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="MinWidth" Value="150"/>
                    <Setter Property="MinHeight" Value="38"/>
                    <Setter Property="Padding" Value="10,6,8,6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Theme_BorderLight}"
                                        Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter Content="{TemplateBinding Header}"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource Theme_AccentLight}"/>
                                        <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,1"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Theme_AccentDark}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource Theme_ButtonHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <!-- ═══════ 压缩 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconCompress" Text="📦" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Compress}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <TextBlock Text="{l:L Settings_Compress_DefaultFormat}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="DefaultFormatCombo" Width="300" HorizontalAlignment="Left" Background="{DynamicResource Theme_WindowBg}" >
                            <ComboBoxItem Content="ZIP (.zip)" Tag="zip"/>
                            <ComboBoxItem Content="7z (.7z)" Tag="7z"/>
                            <ComboBoxItem Content="TAR.GZ (.tar.gz)" Tag="tar.gz"/>
                        </ComboBox>

                        <TextBlock Text="{l:L Settings_Compress_DefaultLevel}" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <ComboBox x:Name="DefaultLevelCombo" Width="300" HorizontalAlignment="Left"  Background="{DynamicResource Theme_WindowBg}">
                            <ComboBoxItem Tag="0" Content="{l:L Compress_Level_Store}"/>
                            <ComboBoxItem Tag="3" Content="{l:L Compress_Level_Fast}"/>
                            <ComboBoxItem Tag="5" Content="{l:L Compress_Level_Normal}"/>
                            <ComboBoxItem Tag="9" Content="{l:L Compress_Level_Max}"/>
                        </ComboBox>

                        <CheckBox x:Name="CloseAfterCompressCheck" Content="{l:L Settings_Compress_CloseAfterDone}" Margin="0,16,0,0"/>
                        <CheckBox x:Name="KeepExtCheck" Content="{l:L Settings_Compress_KeepExt}" Margin="0,8,0,0"/>
                        <CheckBox x:Name="PreserveRootCheck" Content="压缩文件夹时保留外层目录" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 解压 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconExtract" Text="📂" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Extract}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <TextBlock Text="{l:L Settings_Extract_DefaultDest}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ExtractDestCombo" Width="300" HorizontalAlignment="Left"  Background="{DynamicResource Theme_WindowBg}">
                            <ComboBoxItem Content="{l:L Settings_Extract_Dest_Ask}" Tag="ask"/>
                            <ComboBoxItem Content="{l:L Settings_Extract_Dest_SameDir}" Tag="same-dir"/>
                            <ComboBoxItem Content="{l:L Settings_Extract_Dest_Desktop}" Tag="desktop"/>
                        </ComboBox>

                        <TextBlock Text="{l:L Settings_Extract_ConflictAction}" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <ComboBox x:Name="ConflictCombo" Width="300" HorizontalAlignment="Left" Background="{DynamicResource Theme_WindowBg}">
                            <ComboBoxItem Content="{l:L Settings_Extract_Conflict_Ask}" Tag="ask"/>
                            <ComboBoxItem Content="{l:L CompressConflict_Overwrite}" Tag="overwrite"/>
                            <ComboBoxItem Content="{l:L Settings_Extract_Conflict_OverwriteOlder}" Tag="overwrite-if-older"/>
                            <ComboBoxItem Content="{l:L Settings_Extract_Conflict_OverwriteSmaller}" Tag="overwrite-if-smaller"/>
                            <ComboBoxItem Content="{l:L CompressConflict_Rename}" Tag="rename"/>
                            <ComboBoxItem Content="{l:L Error_Skip}" Tag="skip"/>
                        </ComboBox>

                        <CheckBox x:Name="OpenFolderCheck" Content="{l:L Settings_Extract_OpenFolderAfter}" Margin="0,16,0,0"/>
                        <CheckBox x:Name="EnableDragExtractCheck" Content="{l:L Settings_Extract_EnableDragExtract}" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 外观 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconAppearance" Text="🎨" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Appearance}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <TextBlock Text="{l:L Settings_Appearance_Theme}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ThemeCombo" Width="300" HorizontalAlignment="Left"
                                  Background="{DynamicResource Theme_WindowBg}"
                                  SelectionChanged="ThemeCombo_SelectionChanged">
                            <ComboBoxItem Tag="Light" Content="{l:L Settings_Appearance_Theme_Light}"/>
                            <ComboBoxItem Tag="Dark" Content="{l:L Settings_Appearance_Theme_Dark}"/>
                        </ComboBox>

                        <TextBlock Text="{l:L Settings_Appearance_MaxRecentFiles}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                        <TextBox x:Name="MaxRecentFilesBox" Width="100" HorizontalAlignment="Left"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 上下文菜单 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconContextMenu" Text="🖱️" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_ContextMenu}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <GroupBox Header="{l:L Settings_Menu_GroupHeader}" Padding="8" Margin="0,0,0,12">
                            <StackPanel>
                                <GroupBox Header="{l:L Settings_Menu_Group_Browse}" Padding="6" Margin="0,0,0,8">
                                    <CheckBox x:Name="EnableOpenCheck" Content="{l:L Settings_Menu_EnableOpen}" Margin="4"/>
                                </GroupBox>
                                <GroupBox Header="{l:L Settings_Menu_Group_Compress}" Padding="6" Margin="0,0,0,8">
                                    <StackPanel>
                                        <CheckBox x:Name="EnableCompressCheck" Content="{l:L Settings_Menu_EnableCompress}" Margin="0,4"/>
                                        <CheckBox x:Name="EnableCompressSeparateCheck" Content="{l:L Settings_Menu_EnableCompressSeparate}" Margin="0,4"/>
                                        <CheckBox x:Name="EnableCompressCombinedCheck" Content="{l:L Settings_Menu_EnableCompressCombined}" Margin="0,4"/>
                                    </StackPanel>
                                </GroupBox>
                                <GroupBox Header="{l:L Settings_Menu_Group_Extract}" Padding="6" Margin="0,0,0,8">
                                    <StackPanel>
                                        <CheckBox x:Name="EnableExtractHereCheck" Content="{l:L Settings_Menu_EnableExtractHere}" Margin="0,4"/>
                                        <CheckBox x:Name="EnableSmartCheck" Content="{l:L Shell_SmartExtract}" Margin="0,4"/>
                                        <CheckBox x:Name="EnableExtractToNamedCheck" Content="{l:L Settings_Menu_EnableExtractToNamed}" Margin="0,4"/>
                                        <CheckBox x:Name="EnableExtractToCheck" Content="{l:L Settings_Menu_EnableExtractTo}" Margin="0,4"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{l:L Settings_Menu_DisplayGroup}" Padding="8" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox x:Name="CascadeCheck" Content="{l:L Settings_Menu_Cascade}" Margin="0,4"/>
                                <CheckBox x:Name="ShowIconsCheck" Content="{l:L Settings_Menu_ShowIcons}" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{l:L Settings_Menu_StatusGroup}" Padding="8">
                            <StackPanel>
                                <TextBlock x:Name="ShellStatusText" Text="{l:L Settings_Menu_Checking}" Margin="0,0,0,8" Foreground="#555"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="InstallBtn" Content="{l:L Settings_Menu_Btn_Install}" Width="60" Height="26"
                                            Click="InstallBtn_Click" IsEnabled="False"/>
                                    <Button x:Name="UninstallBtn" Content="{l:L Settings_Menu_Btn_Uninstall}" Width="60" Height="26" Margin="6,0,0,0"
                                            Click="UninstallBtn_Click" IsEnabled="False"/>
                                    <Button x:Name="ApplyShellBtn" Content="{l:L Settings_Menu_Btn_Apply}" Width="60" Height="26" Margin="6,0,0,0"
                                            Click="ApplyShellBtn_Click" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 预览（含子面板）═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconPreview" Text="👁" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Preview}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <Grid>
                    <!-- 嵌套 TabControl 作为子面板 -->
                    <TabControl x:Name="PreviewSubTabs" TabStripPlacement="Top"
                                Background="{StaticResource Theme_SurfaceBg}"
                                BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem" x:Key="PreviewSubTabStyle">
                                <Setter Property="MinWidth" Value="60"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="Background" Value="{StaticResource Theme_WindowBg}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Bd" BorderThickness="0,0,0,2"
                                                    BorderBrush="Transparent"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="{TemplateBinding Header}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="13"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Theme_AccentDark}"/>
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Theme_AccentLight}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Theme_ButtonHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- ── 通用 ── -->
                        <TabItem Header="{l:L Settings_Preview_Tab_General}" Style="{StaticResource PreviewSubTabStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="ShowPreviewPanelCheck" Content="{l:L Settings_Preview_EnablePanel}" Margin="0,0,0,8"/>

                                    <TextBlock Text="{l:L Settings_Preview_Position}" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="PreviewPositionCombo" Width="300" HorizontalAlignment="Left" Margin="0,0,0,8"
                                              Background="{DynamicResource Theme_WindowBg}">
                                        <ComboBoxItem Tag="1" IsSelected="True" Content="{l:L Settings_Preview_Pos_Bottom}"/>
                                        <ComboBoxItem Tag="2" Content="{l:L Settings_Preview_Pos_BelowTree}"/>
                                        <ComboBoxItem Tag="3" Content="{l:L Settings_Preview_Pos_BelowList}"/>
                                        <ComboBoxItem Tag="4" Content="{l:L Settings_Preview_Pos_RightOfList}"/>
                                    </ComboBox>

                                    <TextBlock Text="{l:L Settings_Preview_InfoDirection}" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="InfoPanelOrientationCombo" Width="300" HorizontalAlignment="Left" Margin="0,0,0,8"
                                              Background="{DynamicResource Theme_WindowBg}">
                                        <ComboBoxItem Tag="Horizontal" IsSelected="True" Content="{l:L Settings_Preview_Dir_Horizontal}"/>
                                        <ComboBoxItem Tag="Vertical" Content="{l:L Settings_Preview_Dir_Vertical}"/>
                                    </ComboBox>

                                    <TextBlock Text="{l:L Settings_Preview_MaxFileSize}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="MaxPreviewSizeSlider" Width="220" Minimum="1" Maximum="100"
                                                Value="15" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                        <TextBox x:Name="MaxPreviewSizeInput" Width="50" Height="22" Margin="8,0,0,0"
                                                 VerticalAlignment="Center" Text="15"
                                                 PreviewTextInput="IntInput_PreviewTextInput"
                                                 TextChanged="MaxPreviewSizeInput_TextChanged"/>
                                        <TextBlock Text="MB" FontSize="12" Foreground="{StaticResource Theme_TextSecondary}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{l:L Settings_Preview_MaxSizeHint}" Foreground="{StaticResource Theme_TextDisabled}" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ── 图片 ── -->
                        <TabItem Header="{l:L Settings_Preview_Tab_Image}" Style="{StaticResource PreviewSubTabStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="EnableImagePreviewCheck" Content="{l:L Settings_Preview_EnableImage}" Margin="0,4"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ── 文本 ── -->
                        <TabItem Header="{l:L Settings_Preview_Tab_Text}" Style="{StaticResource PreviewSubTabStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="EnableTextPreviewCheck" Content="{l:L Settings_Preview_EnableText}" Margin="0,4,0,8"/>

                                    <TextBlock Text="{l:L Settings_Preview_TextFontSize}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="TextFontSizeSlider" Width="200" Minimum="8" Maximum="36"
                                                Value="12" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                        <TextBlock x:Name="TextFontSizeText" Text="12" Width="30" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border BorderBrush="{StaticResource Theme_Border}" BorderThickness="1" Padding="8" Margin="0,8,0,0"
                                            Background="{StaticResource Theme_SurfaceBg}" CornerRadius="4">
                                        <TextBlock x:Name="TextFontSizeSample" FontSize="12"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   Text="{l:L Settings_Preview_TextSample}"
                                                   TextWrapping="Wrap"/>
                                    </Border>

                                    <TextBlock Text="{l:L Settings_Preview_TextFontFamily}" FontWeight="SemiBold" Margin="0,16,0,4"/>
                                    <ComboBox x:Name="TextFontFamilyCombo" Width="300" HorizontalAlignment="Left" Background="{DynamicResource Theme_WindowBg}"/>

                                    <TextBlock Text="{l:L Settings_Preview_MaxTextSize}" FontWeight="SemiBold" Margin="0,16,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="MaxTextSizeSlider" Width="200" Minimum="1" Maximum="50"
                                                Value="5" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                        <TextBlock x:Name="MaxTextSizeText" Text="5 MB" Width="50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <CheckBox x:Name="UseColorEmojiCheck" Content="{l:L Settings_Preview_ColorEmoji}" Margin="0,16,0,0"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ── 字体 ── -->
                        <TabItem Header="{l:L Settings_Preview_Tab_Font}" Style="{StaticResource PreviewSubTabStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{l:L Settings_Preview_FontSampleText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox x:Name="FontPreviewSampleBox" Height="200" AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalAlignment="Stretch"/>

                                    <TextBlock Text="{l:L Settings_Preview_FontPreviewSize}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Slider x:Name="FontPreviewSizeSlider" Width="200" Minimum="8" Maximum="36"
                                                Value="12" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                        <TextBlock x:Name="FontPreviewSizeText" Text="12" Width="30" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="{l:L Settings_Preview_FontSampleHint}"
                                               Foreground="{StaticResource Theme_TextDisabled}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ── 种子 ── -->
                        <TabItem Header="{l:L Settings_Preview_Tab_Torrent}" Style="{StaticResource PreviewSubTabStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{l:L Settings_Preview_Placeholder}"
                                               Foreground="{StaticResource Theme_TextDisabled}" FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ── 可执行文件 ── -->
                        <TabItem Header="{l:L Settings_Preview_Tab_PE}" Style="{StaticResource PreviewSubTabStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{l:L Settings_Preview_Placeholder}"
                                               Foreground="{StaticResource Theme_TextDisabled}" FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ── 数据表格 ── -->
                        <TabItem Header="{l:L Settings_Preview_Tab_Datatable}" Style="{StaticResource PreviewSubTabStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{l:L Settings_Preview_MaxTableRows}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox x:Name="MaxTableRowsBox" Width="120" Height="24" HorizontalAlignment="Left"
                                             PreviewTextInput="IntInput_PreviewTextInput"
                                             TextChanged="MaxTableRows_TextChanged"/>
                                    <TextBlock Text="{l:L Settings_Preview_MaxTableCols}" FontWeight="SemiBold" Margin="0,16,0,4"/>
                                    <TextBox x:Name="MaxTableColsBox" Width="120" Height="24" HorizontalAlignment="Left"
                                             PreviewTextInput="IntInput_PreviewTextInput"
                                             TextChanged="MaxTableCols_TextChanged"/>
                                    <TextBlock Text="{l:L Settings_Preview_MaxTableRangeHint}"
                                               Foreground="{StaticResource Theme_TextDisabled}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,16,0,0"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <!-- ═══════ 文件关联 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconFileAssoc" Text="🔗" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_FileAssoc}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <GroupBox Header="{l:L Settings_Assoc_GroupHeader}" Padding="8" Margin="0,0,0,12">
                            <StackPanel>
                                <!-- 描述文字 -->
                                <TextBlock Text="{l:L Settings_Assoc_Desc}" TextWrapping="Wrap"
                                           Foreground="{StaticResource Theme_TextSecondary}"
                                           FontSize="12" Margin="0,0,0,10"/>

                                <!-- 全选/取消全选 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="SelectAllBtn" Content="{l:L Settings_Assoc_SelectAll}"
                                            Width="80" Height="24" FontSize="12" Click="SelectAllBtn_Click"/>
                                    <Button x:Name="DeselectAllBtn" Content="{l:L Settings_Assoc_DeselectAll}"
                                            Width="80" Height="24" FontSize="12" Margin="6,0,0,0"
                                            Click="DeselectAllBtn_Click"/>
                                </StackPanel>

                                <!-- 格式列表 -->
                                <Border BorderBrush="{StaticResource Theme_Border}"
                                        BorderThickness="1" CornerRadius="4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="180">
                                    <ItemsControl x:Name="AssocFormatList"
                                                  Grid.IsSharedSizeScope="True"
                                                  Margin="4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="2,5,2,5" 
                                                       MouseLeftButtonUp="FormatRow_MouseLeftButtonUp">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDefaultStatus}" Value="True">
                                                                    <Setter Property="Background" Value="#1A4CAF50"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsNotDefaultStatus}" Value="True">
                                                                    <Setter Property="Background" Value="#1AFF9800"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Ext"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                                              VerticalAlignment="Center"/>

                                                    <Image Grid.Column="1" Source="{Binding Icon}"
                                                           Width="16" Height="16"
                                                           VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Extension}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0" FontSize="13"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding Description}"
                                                               Foreground="{StaticResource Theme_TextSecondary}"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,0,0" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <!-- 当前关联程序 -->
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding CurrentHandler}"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Margin="8,0,4,0"/>

                                                    <!-- 自定义扩展名的删除按钮 -->
                                                    <Button Grid.Column="5"
                                                            x:Name="DeleteCustomBtn"
                                                            Content="✕"
                                                            Width="36" Height="24" FontSize="12"
                                                            VerticalAlignment="Center"
                                                            Margin="4,0,0,0"
                                                            Visibility="{Binding IsCustom, Converter={StaticResource BoolToVis}}"
                                                            Click="DeleteCustomBtn_Click"
                                                            ToolTip="删除此自定义格式"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                </Border>

                                <!-- 添加自定义扩展名按钮 -->
                                <Button x:Name="AddCustomBtn"
                                        Content="{l:L Settings_Assoc_AddCustom}"
                                        Width="160" Height="26"
                                        HorizontalAlignment="Left" Margin="0,8,0,0"
                                        Click="AddCustomBtn_Click"/>

                                <!-- 状态 -->
                                <TextBlock x:Name="AssocStatusText" Text="" FontSize="11"
                                           Foreground="{StaticResource Theme_TextSecondary}"
                                           Margin="0,8,0,0"/>

                                <!-- 底部按钮行 -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button x:Name="OpenDefaultAppsBtn"
                                            Content="{l:L Settings_Assoc_OpenDefaultApps}"
                                            Width="120" Height="28"
                                            Click="OpenDefaultAppsBtn_Click"/>
                                    <Button x:Name="InstallAssocBtn"
                                            Content="{l:L Settings_Assoc_Install}"
                                            Width="100" Height="28" Margin="8,0,0,0"
                                            Click="InstallAssoc_Click"/>
                                    <Button x:Name="UninstallAssocBtn"
                                            Content="{l:L Settings_Assoc_Uninstall}"
                                            Width="100" Height="28" Margin="8,0,0,0"
                                            Click="UninstallAssoc_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 密码管理 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconPassword" Text="🔐" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Password}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="ShowPasswordNotifCheck" Content="{l:L Settings_Pwd_ShowNotification}" Margin="0,4"/>
                        <TextBlock Text="{l:L Settings_Pwd_ShowHint}" Foreground="{StaticResource Theme_TextDisabled}" FontSize="11" TextWrapping="Wrap" Margin="24,0,0,12"/>

                        <CheckBox x:Name="RevealPasswordCheck" Content="{l:L Settings_Pwd_RevealDefault}" Margin="0,12,0,4"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 语言 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconLanguage" Text="🌐" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Language}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <TextBlock Text="{l:L Settings_Language}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="LanguageCombo" Width="300" Height="26" HorizontalAlignment="Left"
                                  SelectionChanged="LanguageCombo_SelectionChanged"/>
                        <TextBlock x:Name="LanguageTranslatorText" FontSize="11"
                                   Foreground="{StaticResource Theme_TextSecondary}"
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 调试 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconDebug" Text="🐛" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Debug}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="EnableDebugLogCheck" Content="{l:L Settings_Advanced_EnableDebugLog}" Margin="0,0,0,2"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource Theme_TextDisabled}" Margin="24,0,0,0">
                            <Run Text="{l:L Settings_Advanced_LogFile}"/>
                            <Run x:Name="LogPathText" Foreground="{StaticResource Theme_TextSecondary}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="24,4,0,0">
                            <Button Content="{l:L Settings_Advanced_OpenLog}" Width="90" Height="22" FontSize="11"
                                    Click="OpenLogFolder_Click"/>
                        </StackPanel>
                        <TextBlock Text="{l:L Settings_Debug_LogPrivacyMode}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="LogPrivacyModeCombo" Width="300" HorizontalAlignment="Left">
                                <ComboBoxItem Tag="off" Content="{l:L Settings_Debug_LogPrivacyMode_Off}"/>
                                <ComboBoxItem Tag="filename" Content="{l:L Settings_Debug_LogPrivacyMode_Filename}"/>
                                <ComboBoxItem Tag="extension" Content="{l:L Settings_Debug_LogPrivacyMode_Extension}"/>
                                <ComboBoxItem Tag="full" Content="{l:L Settings_Debug_LogPrivacyMode_Full}"/>
                            </ComboBox>
                            <Button Content="?" Width="28" Height="22" Margin="6,0,0,0" FontSize="12" FontWeight="Bold"
                                    Click="LogPrivacyHelp_Click" ToolTip="{l:L Settings_Debug_LogPrivacyHelp_Title}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ 高级 ═══════ -->
            <TabItem>
                <TabItem.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <emoji:TextBlock x:Name="IconAdvanced" Text="🧰" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Advanced}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Theme_SurfaceBg}">
                    <StackPanel Margin="10">
                        <!-- 7z.dll 配置 -->
                        <GroupBox Header="{l:L Settings_Advanced_SevenZipGroupHeader}" Padding="8" Margin="0,0,0,12">
                            <StackPanel>
                                <!-- 状态行 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                        <Run Text="{l:L Settings_Advanced_SevenZipStatus}"/><Run Text=":"/>
                                    </TextBlock>
                                    <TextBlock x:Name="SevenZipStatusIcon" Margin="8,0,4,0" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SevenZipStatusText" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- 路径显示（只读） -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                        <Run Text="{l:L Settings_Advanced_SevenZipPath}"/><Run Text=":"/>
                                    </TextBlock>
                                    <TextBlock x:Name="SevenZipCurrentPathText" Margin="8,0,0,0" VerticalAlignment="Center"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxWidth="400"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                </StackPanel>
                                <!-- 操作按钮 -->
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="SevenZipBrowseBtn" Content="{l:L Settings_Advanced_Browse}" Width="90" Height="26"
                                            Click="SevenZipBrowseBtn_Click"/>
                                    <Button x:Name="SevenZipResetBtn" Content="{l:L Settings_Advanced_SevenZipReset}" Width="100"
                                            Height="26" Margin="8,0,0,0" Click="SevenZipResetBtn_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <Button Content="{l:L Settings_Advanced_CleanPreviewTemp}" Width="140" Height="26" Margin="0,0,0,0"
                                HorizontalAlignment="Left" Click="CleanTemp_Click"/>

                        <TextBlock Text="{l:L Settings_Advanced_AboutHeader}" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Theme_TextSecondary}" FontSize="11">
                            <Run Text="{l:L Settings_Advanced_AboutVersion}"/><Run x:Name="AboutVersionText"/>
                            <LineBreak/>
                            <Run Text="{l:L Settings_Advanced_AboutDesc}"/>
                            <LineBreak/>
                            <Run Text="{l:L Settings_Advanced_AboutLicense}"/>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SaveBtn" Content="{l:L PwdEdit_Save}" Width="80" Height="28" Click="SaveBtn_Click"/>
            <Button Content="{l:L MsgBox_Cancel}" Width="80" Height="28" Margin="8,0,0,0" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
