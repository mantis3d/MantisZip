<Window x:Class="MantisZip.UI.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
        Title="{l:L Pwd_Title}" Height="320" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Theme_WindowBg}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="FileNameText" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>

        <ComboBox x:Name="PasswordSelector" Grid.Row="1" IsEditable="False"
                  FontSize="13" Padding="6,4" Margin="0,0,0,4"
                  SelectionChanged="PasswordSelector_SelectionChanged">
            <ComboBoxItem Content="{l:L Pwd_NewPasswordOption}"/>
        </ComboBox>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <PasswordBox x:Name="PasswordBox"
                            FontSize="14" Padding="6,4"
                            KeyDown="PasswordBox_KeyDown"/>
                <TextBox x:Name="PasswordPlainBox"
                        FontSize="14" Padding="6,4"
                        Visibility="Collapsed"
                        KeyDown="PasswordBox_KeyDown"/>
            </Grid>

            <Button x:Name="PwdRevealBtn" Grid.Column="1"
                    Width="28" Height="24" Margin="6,0,0,0"
                    Content="👁" FontSize="12" Padding="0"
                    Background="{StaticResource Theme_ButtonBg}" BorderThickness="1"
                    BorderBrush="{StaticResource Theme_Border}" Foreground="{StaticResource Theme_TextSecondary}"
                    Cursor="Hand" ToolTip="{l:L PwdMgr_Col_Password}"
                    Click="PwdRevealBtn_Click"/>
        </Grid>

        <CheckBox x:Name="RememberCheckBox" Grid.Row="3" Content="{l:L Pwd_Remember}"
                  Margin="0,8,0,4" IsChecked="True"
                  Checked="RememberCheckBox_Changed" Unchecked="RememberCheckBox_Changed"/>

        <StackPanel Grid.Row="4" Margin="16,0,0,0" IsEnabled="{Binding IsChecked, ElementName=RememberCheckBox}">
            <TextBlock Text="{l:L Pwd_Description}" FontSize="11" Foreground="{StaticResource Theme_TextDisabled}" Margin="0,0,0,2"/>
            <TextBox x:Name="DescTextBox" FontSize="12" Padding="4,2" Height="22"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="16,4,0,0" IsEnabled="{Binding IsChecked, ElementName=RememberCheckBox}">
            <TextBlock Text="{l:L Pwd_MatchRules}" FontSize="11" Foreground="{StaticResource Theme_TextDisabled}" Margin="0,0,0,2"/>
                            <TextBox x:Name="PatternsTextBox" FontSize="12" Padding="4,2" Height="50"
                                     AcceptsReturn="True" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{l:L MsgBox_Ok}" Click="Ok_Click" Width="80" Height="30" Margin="0,0,8,0"
                    IsDefault="True" Background="{StaticResource Theme_Accent}" Foreground="{StaticResource Theme_TextOnAccent}"/>
            <Button Content="{l:L MsgBox_Cancel}" Click="Cancel_Click" Width="80" Height="30"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
