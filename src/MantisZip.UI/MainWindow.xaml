<Window x:Class="MantisZip.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:app="clr-namespace:MantisZip.UI"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        mc:Ignorable="d"
        Title="{l:L Main_WindowTitle}" Icon="/Resources/App.ico" Height="800" Width="1200"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Background="{StaticResource Theme_WindowBg}"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <app:RatioToWidthConverter x:Key="RatioToWidthConverter"/>
        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
        </Style>

        <!-- 列标题右键菜单（切换列显隐） -->
        <ContextMenu x:Key="ColumnHeaderContextMenu"/>

        <!-- DataGrid 列标题样式：适配主题 + 右键菜单 -->
        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,0,8,0"/>
            <Setter Property="Background" Value="{StaticResource Theme_HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource Theme_TextSecondary}"/>
            <Setter Property="ContextMenu" Value="{StaticResource ColumnHeaderContextMenu}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="{l:L Main_Menu_File}">
                <MenuItem Header="{l:L Main_Menu_OpenArchive}" Click="OpenArchive_Click" InputGestureText="Ctrl+O">
                    <MenuItem.Icon><emoji:TextBlock Text="📂" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{l:L Main_Menu_NewArchive}" Click="NewArchive_Click" InputGestureText="Ctrl+N">
                    <MenuItem.Icon><emoji:TextBlock Text="🆕" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{l:L Main_Menu_Extract}" Click="Extract_Click" InputGestureText="Ctrl+E">
                    <MenuItem.Icon><emoji:TextBlock Text="📤" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{l:L Main_Menu_Compress}" Click="Compress_Click" InputGestureText="Ctrl+C">
                    <MenuItem.Icon><emoji:TextBlock Text="📥" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{l:L Main_Menu_Exit}" Click="Exit_Click" InputGestureText="Alt+F4">
                    <MenuItem.Icon><emoji:TextBlock Text="🚪" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{l:L Main_Menu_View}">
                <MenuItem Header="{l:L Main_Menu_Refresh}" Click="Refresh_Click" InputGestureText="F5">
                    <MenuItem.Icon><emoji:TextBlock Text="🔄" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="ShowProgressBarsMenu" Header="{l:L Main_Menu_ProgressBars}"
                          IsCheckable="True" IsChecked="True" Click="ToggleProgressBars_Click">
                    <MenuItem.Icon><emoji:TextBlock Text="📊" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="SepDirBaselineMenu" Header="{l:L Main_Menu_SepDirBaseline}"
                          IsCheckable="True" IsChecked="False" Click="ToggleSepDirBaseline_Click">
                    <MenuItem.Icon><emoji:TextBlock Text="📂" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center" Opacity="0.2"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{l:L Main_Menu_Edit}">
                <MenuItem x:Name="EditMenuAddFiles" Header="{l:L Main_Ctx_AddFiles}" Click="AddFiles_Click">
                    <MenuItem.Icon><emoji:TextBlock Text="➕" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="EditMenuDeleteFiles" Header="{l:L Main_Ctx_DeleteFiles}" Click="DeleteFiles_Click">
                    <MenuItem.Icon><emoji:TextBlock Text="✖" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="EditMenuArchiveComment" Header="{l:L Main_Menu_ArchiveComment}" Click="EditArchiveComment_Click">
                    <MenuItem.Icon><emoji:TextBlock Text="💬" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{l:L Main_Menu_Tools}">
                <MenuItem Header="{l:L Main_Menu_PasswordManager}" Click="PasswordManager_Click">
                    <MenuItem.Icon><emoji:TextBlock Text="🔑" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{l:L Main_Menu_Settings}" Click="Settings_Click">
                    <MenuItem.Icon><emoji:TextBlock Text="⚙" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{l:L Main_Menu_Help}">
                <MenuItem Header="{l:L Main_Menu_About}" Click="About_Click">
                    <MenuItem.Icon><emoji:TextBlock Text="ℹ" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource Theme_MenuBg}">
            <ToolBar>
                <Button ToolTip="{l:L Main_Tooltip_NewArchive}" Click="NewArchive_Click" Padding="8,6">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="🆕" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_New}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button ToolTip="{l:L Main_Tooltip_OpenArchive}" Click="OpenArchive_Click" Padding="8,6">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="📂" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_Open}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button ToolTip="{l:L Main_Tooltip_Extract}" Click="Extract_Click" Padding="8,6">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="📤" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Extract}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button ToolTip="{l:L Main_Tooltip_Compress}" Click="Compress_Click" Padding="8,6">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="📥" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Shell_Compress}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SmartExtractBtn" ToolTip="{l:L Main_Tooltip_SmartExtract}" Click="SmartExtract_Click" Padding="8,6" IsEnabled="False">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="🤖" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_SmartExtract}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button x:Name="AddFilesBtn" ToolTip="{l:L Main_Tooltip_AddFiles}" Click="AddFiles_Click" Padding="8,6" IsEnabled="False">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="➕" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_AddFiles}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="DeleteFilesBtn" ToolTip="{l:L Main_Tooltip_DeleteFiles}" Click="DeleteFiles_Click" Padding="8,6" IsEnabled="False">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="✖" FontSize="25" Foreground="{StaticResource Theme_StatusError}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_DeleteFiles}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button ToolTip="{l:L Main_Tooltip_Test}" Click="TestArchive_Click" Padding="8,6">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="✓" FontSize="25" Foreground="{StaticResource Theme_StatusSuccess}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_Test}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button x:Name="EnterPasswordBtn" ToolTip="{l:L Main_Tooltip_Password}" Click="EnterPassword_Click" Padding="8,6" IsEnabled="False">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="🔑" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L PwdMgr_Col_Password}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <ToggleButton x:Name="PreviewToggleBtn" ToolTip="{l:L Main_Tooltip_Preview}" Click="PreviewToggleBtn_Click" Padding="8,6">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <emoji:TextBlock x:Name="PreviewToggleIcon" Text="👁" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Preview}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
            </ToolBar>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="8">
            <Border Background="{StaticResource Theme_SurfaceBg}" CornerRadius="4" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- No Archive Loaded - Drop Hint -->
                    <Border x:Name="DropHint" Grid.Row="1" Visibility="Visible"
                            Background="{StaticResource Theme_WindowBg}" BorderBrush="{StaticResource Theme_Border}" BorderThickness="2" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <emoji:TextBlock Text="📁" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="{l:L Main_EmptyDropHint}" FontSize="16" Foreground="{StaticResource Theme_TextDisabled}" Margin="0,16,0,4"/>
                            <Button Content="{l:L Main_OpenArchiveBtn}" FontSize="14" Click="OpenArchive_Click" 
                                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource Theme_Accent}" Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <!-- Archive Loaded - File List -->
                    <Grid x:Name="FileListPanel" Grid.Row="1" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Archive Info -->
                        <Border Grid.Row="0" Background="{StaticResource Theme_AccentLight}" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📦" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="ArchiveNameText" Text="" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock x:Name="ArchiveInfoText" Text="" FontSize="11" Foreground="{StaticResource Theme_TextSecondary}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- TreeView + FileList + Preview -->
                        <Grid Grid.Row="1" x:Name="ContentGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" MinWidth="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="100"/>
                                <ColumnDefinition x:Name="PreviewColSplitterDef" Width="Auto" MinWidth="0"/>
                                <ColumnDefinition x:Name="PreviewColumnDef" Width="0" MinWidth="0"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition x:Name="PreviewSplitterRow" Height="0"/>
                                <RowDefinition x:Name="PreviewRow" Height="0"/>
                            </Grid.RowDefinitions>

                            <!-- TreeView + DataGrid -->
                            <Grid x:Name="InnerContentGrid" Grid.Row="0" Grid.ColumnSpan="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition x:Name="InnerPreviewSplitterRow" Height="0"/>
                                    <RowDefinition x:Name="InnerPreviewRow" Height="0"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="TreeColumn" Width="396" MinWidth="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition x:Name="FileListColumn" Width="*" MinWidth="100"/>
                                    <ColumnDefinition x:Name="InnerPreviewColSplitterDef" Width="Auto" MinWidth="0"/>
                                    <ColumnDefinition x:Name="InnerPreviewColumnDef" Width="0" MinWidth="0"/>
                                </Grid.ColumnDefinitions>

                                <!-- Directory Tree -->
                                <TreeView x:Name="FolderTree" Grid.Column="0" 
                                          BorderThickness="1" BorderBrush="{StaticResource Theme_BorderLight}"
                                          SelectedItemChanged="FolderTree_SelectedItemChanged"
                                          ItemContainerStyle="{StaticResource TreeViewItemStyle}">
                                    <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>

                                <GridSplitter x:Name="TreeFileSplitter" Grid.Column="1" Width="4" Background="Transparent" 
                                            HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                                <!-- File List -->
                                <DataGrid x:Name="FileListGrid" Grid.Column="2"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Extended"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          ColumnHeaderHeight="28"
                                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                          Background="{StaticResource Theme_SurfaceBg}"
                                          VirtualizingStackPanel.IsVirtualizing="True"
                                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                                          EnableRowVirtualization="True"
                                          ScrollViewer.IsDeferredScrollingEnabled="False"
                                          BorderThickness="1"
                                          BorderBrush="{StaticResource Theme_BorderLight}"
                                            SelectionChanged="FileListGrid_SelectionChanged"
                                           PreviewMouseDoubleClick="FileListGrid_PreviewMouseDoubleClick"
                                            PreviewMouseLeftButtonDown="FileListGrid_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="FileListGrid_PreviewMouseMove"
                                            PreviewKeyDown="FileListGrid_PreviewKeyDown"
                                            Sorting="FileListGrid_Sorting">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{l:L Main_Ctx_AddFiles}" Click="FileListCtx_AddFiles">
                                                <MenuItem.Icon><emoji:TextBlock Text="➕" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{l:L Main_Ctx_DeleteFiles}" Click="FileListCtx_DeleteFiles">
                                                <MenuItem.Icon><emoji:TextBlock Text="✖" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                                            </MenuItem>
                                            <Separator/>
                                            <MenuItem Header="{l:L Main_Ctx_ExtractTo}" Click="FileListCtx_ExtractTo">
                                                <MenuItem.Icon><emoji:TextBlock Text="📤" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{l:L Main_Ctx_ExtractHere}" Click="FileListCtx_ExtractHere">
                                                <MenuItem.Icon><emoji:TextBlock Text="📂" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                                            </MenuItem>
                                            <Separator/>
                                            <MenuItem Header="{l:L Main_Ctx_CopyName}" Click="FileListCtx_CopyName">
                                                <MenuItem.Icon><emoji:TextBlock Text="📋" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{l:L Main_Ctx_CopyPath}" Click="FileListCtx_CopyPath">
                                                <MenuItem.Icon><emoji:TextBlock Text="🔗" FontSize="14" Margin="2,0,4,0" VerticalAlignment="Center"/></MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="{l:L Main_Col_Name}" Width="*" SortMemberPath="Name">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding NameDisplay}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{l:L Main_Col_Size}" Width="100" SortMemberPath="Size">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Rectangle HorizontalAlignment="Left">
                                                            <Rectangle.Style>
                                                                <Style TargetType="Rectangle">
                                                                    <Setter Property="Fill" Value="{StaticResource ProgressBarSizeBg}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UseDirProgressColor}" Value="True">
                                                                            <Setter Property="Fill" Value="{StaticResource ProgressBarSizeDirBg}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Rectangle.Style>
                                                            <Rectangle.Width>
                                                                <MultiBinding Converter="{StaticResource RatioToWidthConverter}">
                                                                    <Binding Path="SizeRatio"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ContentPresenter}"/>
                                                                </MultiBinding>
                                                            </Rectangle.Width>
                                                        </Rectangle>
                                                        <TextBlock Text="{Binding SizeDisplay}" VerticalAlignment="Center" Margin="4,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{l:L Main_Col_Compressed}" Width="100" SortMemberPath="CompressedSize">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Rectangle HorizontalAlignment="Left">
                                                            <Rectangle.Style>
                                                                <Style TargetType="Rectangle">
                                                                    <Setter Property="Fill" Value="{StaticResource ProgressBarCompressedSizeBg}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UseDirProgressColor}" Value="True">
                                                                            <Setter Property="Fill" Value="{StaticResource ProgressBarCompressedSizeDirBg}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Rectangle.Style>
                                                            <Rectangle.Width>
                                                                <MultiBinding Converter="{StaticResource RatioToWidthConverter}">
                                                                    <Binding Path="CompressedSizeRatio"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ContentPresenter}"/>
                                                                </MultiBinding>
                                                            </Rectangle.Width>
                                                        </Rectangle>
                                                        <TextBlock Text="{Binding CompressedSizeDisplay}" VerticalAlignment="Center" Margin="4,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{l:L Main_Col_Ratio}" Width="80" SortMemberPath="RatioSort">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Rectangle Fill="{StaticResource ProgressBarRatioBg}" HorizontalAlignment="Left">
                                                            <Rectangle.Width>
                                                                <MultiBinding Converter="{StaticResource RatioToWidthConverter}">
                                                                    <Binding Path="RatioBarValue"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ContentPresenter}"/>
                                                                </MultiBinding>
                                                            </Rectangle.Width>
                                                        </Rectangle>
                                                        <TextBlock Text="{Binding RatioDisplay}" VerticalAlignment="Center" Margin="4,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="{l:L Main_Col_Crc32}" Binding="{Binding Crc32Display}" SortMemberPath="Crc32" Width="110"/>
                                        <DataGridTemplateColumn Header="{l:L Main_Col_Date}" Width="150" SortMemberPath="LastModified">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Rectangle Fill="{StaticResource ProgressBarDateBg}" HorizontalAlignment="Left">
                                                            <Rectangle.Width>
                                                                <MultiBinding Converter="{StaticResource RatioToWidthConverter}">
                                                                    <Binding Path="DateRatio"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ContentPresenter}"/>
                                                                </MultiBinding>
                                                            </Rectangle.Width>
                                                        </Rectangle>
                                                        <TextBlock Text="{Binding DateDisplay}" VerticalAlignment="Center" Margin="4,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{l:L Main_Col_Encrypted}" Width="50" SortMemberPath="Encrypted">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <emoji:TextBlock Text="🔒" HorizontalAlignment="Center" 
                                                               Visibility="{Binding IsEncrypted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Inner preview row splitter (Pos 2/3) -->
                                <GridSplitter x:Name="InnerPreviewSplitter" Grid.Row="1"
                                            Height="4" Background="Transparent"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                            Visibility="Collapsed" Grid.ColumnSpan="5"/>

                                <!-- Loading overlay while opening archive -->
                                <Border x:Name="ArchiveLoadingOverlay" Grid.Row="0" Grid.ColumnSpan="5"
                                        Background="{StaticResource Theme_WindowBg}"
                                        Visibility="Collapsed">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="ArchiveLoadingText"
                                                   FontSize="16"
                                                   Foreground="{StaticResource Theme_TextDisabled}"
                                                   HorizontalAlignment="Center"/>
                                        <ProgressBar x:Name="ArchiveLoadingBar" Width="240" Height="6"
                                                     IsIndeterminate="True"
                                                     Margin="0,16,0,0"
                                                     Foreground="{StaticResource Theme_Accent}"/>
                                        <TextBlock x:Name="ArchiveLoadingPercent"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Theme_TextDisabled}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Vertical Splitter for Pos 4 (Right preview) -->
                            <GridSplitter x:Name="PreviewColSplitter" Grid.Row="0" Grid.Column="3"
                                        Width="4" Background="Transparent"
                                        HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                        Visibility="Collapsed"/>

                            <!-- Preview Splitter -->
                            <GridSplitter x:Name="PreviewSplitter" Grid.Row="1" Grid.ColumnSpan="5" Height="4" 
                                        Background="Transparent" HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center" Visibility="Collapsed"/>

                            <!-- Preview Panel -->
                            <Border x:Name="PreviewPanel" Grid.Row="2" Grid.ColumnSpan="5"
                                    Background="{StaticResource Theme_WindowBg}" BorderBrush="{StaticResource Theme_BorderLight}" BorderThickness="1"
                                    CornerRadius="4" Visibility="Collapsed">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <TextBlock x:Name="PreviewHeader" Grid.Row="0"
                                              FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Theme_TextSecondary}"
                                              VerticalAlignment="Top" HorizontalAlignment="Left"/>

                                    <!-- Content area + Info Panel (dual orientation) -->
                                    <Grid x:Name="PreviewContentGrid" Grid.Row="1" Margin="0,16,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Content wrapper with toolbar + content -->
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>  <!-- toolbar -->
                                                    <RowDefinition Height="*"/>     <!-- content -->
                                                </Grid.RowDefinitions>

                                                <!-- Preview Toolbar -->
                                                <Border x:Name="PreviewToolbarBorder" Grid.Row="0"
                                                        Background="{StaticResource Theme_HeaderBg}" CornerRadius="4"
                                                        Padding="6,4" Margin="0,0,0,8"
                                                        Visibility="Collapsed">
                                                    <StackPanel x:Name="PreviewToolbarPanel" Orientation="Horizontal"/>
                                                </Border>

                                                <!-- Content container -->
                                                <Grid Grid.Row="1">

                                            <!-- Image Preview -->
                                            <ScrollViewer x:Name="PreviewImageScroll" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled" Visibility="Collapsed">
                                                <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Visible" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </ScrollViewer>

                                            <!-- File Icon (for non-previewable files) -->
                                            <Image x:Name="PreviewFileIcon" Width="64" Height="64" Visibility="Collapsed"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Text Preview -->
                                            <TextBox x:Name="PreviewTextBox"
                                                     IsReadOnly="True" 
                                                     FontFamily="Cascadia Code, Consolas, monospace"
                                                     FontSize="12"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     TextWrapping="Wrap"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     Visibility="Collapsed"/>

                                            <!-- Tabular Preview Container (CSV/SQLite/etc) -->
                                            <Grid x:Name="PreviewTabularContainer" Visibility="Collapsed"/>

                                            <!-- CSV Grid Preview -->
                                            <DataGrid x:Name="PreviewCsvGrid"
                                                      AutoGenerateColumns="True"
                                                      IsReadOnly="True"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      CanUserReorderColumns="True"
                                                      CanUserResizeColumns="True"
                                                      CanUserSortColumns="True"
GridLinesVisibility="All"
                                                      HeadersVisibility="Column"
                                                      RowHeaderWidth="0"
                                                      Visibility="Collapsed"
                                                      BorderThickness="0"
                                                      Background="Transparent"
                                                      FontSize="12"
                                                      MinColumnWidth="60"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Stretch"/>

                                            <!-- HTML/Markdown/PDF/SVG Preview -->
                                            <wv2:WebView2 x:Name="PreviewWebView2" Visibility="Collapsed"/>

                                            <!-- Loading progress -->
                                            <StackPanel x:Name="PreviewLoadingPanel"
                                                        Visibility="Collapsed"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock x:Name="PreviewLoadingText"
                                                           Text="..."
                                                           FontSize="13" Foreground="{StaticResource Theme_TextDisabled}"
                                                           HorizontalAlignment="Center"/>
                                                <ProgressBar Width="200" Height="8"
                                                             IsIndeterminate="True"
                                                             Margin="0,8,0,0"
                                                             Foreground="{StaticResource Theme_Accent}"/>
                                                <TextBlock x:Name="PreviewLoadingPercent"
                                                           Text=""
                                                           FontSize="11" Foreground="{StaticResource Theme_TextDisabled}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <!-- Unsupported fallback -->
                                            <StackPanel x:Name="PreviewUnsupportedPanel"
                                                        Visibility="Collapsed"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Image x:Name="PreviewUnsupportedIcon"
                                                       Width="48" Height="48"
                                                       HorizontalAlignment="Center"
                                                       Visibility="Collapsed"/>
                                                <TextBlock x:Name="PreviewUnsupportedText"
                                                           FontSize="18"
                                                           Foreground="{StaticResource Theme_TextDisabled}"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,12,0,0"/>
                                            </StackPanel>

                                                </Grid>
                                            </Grid>

                                            <!-- Info Panel (universal) -->
                                            <Border x:Name="PreviewInfoPanel"
                                                    Background="{StaticResource Theme_HeaderBg}" CornerRadius="4" 
                                                    Padding="10" Margin="12,0,0,0"
                                                    MinWidth="160" MinHeight="60">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Row 0: Format-specific info (always on top) -->
                                                    <TextBlock x:Name="PreviewFormatInfo" Grid.Row="0" Grid.ColumnSpan="3"
                                                               FontSize="12" Foreground="{StaticResource Theme_TextSecondary}"
                                                               TextWrapping="Wrap" Margin="0,0,0,4"/>

                                                    <!-- Row 1: Separator -->
                                                    <Rectangle Grid.Row="1" Grid.ColumnSpan="3"
                                                               Height="1" Fill="{StaticResource Theme_BorderLight}" Margin="0,0,0,4"/>

                                                    <!-- Row 2: Dynamic format-specific detail pairs -->
                                                    <StackPanel x:Name="PreviewExtraInfoPanel" Grid.Row="2" Grid.ColumnSpan="3"
                                                                 Margin="0,0,0,8" Visibility="Collapsed"/>

                                                    <!-- Row 3: Separator (通用信息上方分隔线) -->
                                                    <Rectangle x:Name="PreviewGeneralSeparator" Grid.Row="3" Grid.ColumnSpan="3"
                                                               Height="1" Fill="{StaticResource Theme_BorderLight}" Margin="0,0,0,4"/>

                                                    <!-- Row 4: File name -->
                                                    <TextBlock x:Name="PreviewFileNameText" Grid.Row="4" Grid.ColumnSpan="3"
                                                               FontWeight="SemiBold" Foreground="{StaticResource Theme_TextPrimary}" FontSize="12"
                                                               TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>

                                                    <!-- Row 5: Separator -->
                                                <Rectangle Grid.Row="5" Grid.ColumnSpan="3"
                                                           Height="1" Fill="{StaticResource Theme_BorderLight}" Margin="0,0,0,4"/>

                                                <!-- Row 6: Size / Ratio / Compressed -->
                                                <TextBlock x:Name="PreviewSizeText" Grid.Row="6" Grid.Column="0"
                                                           FontSize="11" Foreground="{StaticResource Theme_TextSecondary}"/>
                                                <TextBlock x:Name="PreviewCompressedText" Grid.Row="6" Grid.Column="1"
                                                           FontSize="11" Foreground="{StaticResource Theme_TextSecondary}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock x:Name="PreviewRatioText" Grid.Row="6" Grid.Column="2"
                                                           FontSize="11" Foreground="{StaticResource Theme_TextSecondary}"
                                                           HorizontalAlignment="Right"/>

                                                <!-- Row 7: Date + Encrypted -->
                                                <TextBlock x:Name="PreviewDateText" Grid.Row="7" Grid.Column="0"
                                                           FontSize="11" Foreground="{StaticResource Theme_TextSecondary}"/>
                                                <TextBlock x:Name="PreviewEncryptedText" Grid.Row="7" Grid.Column="2"
                                                           FontSize="11" Foreground="{StaticResource Theme_TextSecondary}"
                                                           HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

<!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="{StaticResource Theme_ProgressBg}">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- Status Text (left) -->
            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusText" Text="{l:L Main_Status_Ready}"/>
            </StatusBarItem>

            <!-- Column 1 = spacer (*) fills center -->

            <!-- Dir Stats -->
            <StatusBarItem Grid.Column="2">
                <TextBlock x:Name="DirStatsText" Margin="4,0,4,0" Foreground="{StaticResource Theme_TextSecondary}"/>
            </StatusBarItem>

            <!-- Selection Stats -->
            <StatusBarItem Grid.Column="3">
                <TextBlock x:Name="SelectionStatsText" Margin="4,0,4,0" Foreground="{StaticResource Theme_TextSecondary}"/>
            </StatusBarItem>

            <!-- Archive Overview -->
            <StatusBarItem Grid.Column="4">
                <TextBlock x:Name="ArchiveStatsText" Margin="4,0,4,0" Foreground="{StaticResource Theme_TextSecondary}"/>
            </StatusBarItem>

            <!-- Password Status -->
            <StatusBarItem Grid.Column="5">
                <TextBlock x:Name="PasswordStatusText" Margin="4,0,4,0" Foreground="{StaticResource Theme_TextSecondary}" FontSize="11"/>
            </StatusBarItem>

            <!-- Progress -->
            <StatusBarItem Grid.Column="6">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar x:Name="ProgressBar" Width="120" Height="14" Visibility="Collapsed"/>
                    <TextBlock x:Name="ProgressText" Margin="4,0,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Version (far right) -->
            <StatusBarItem Grid.Column="7">
                <TextBlock Text="{x:Static app:AppConstants.VersionDisplay}" Foreground="{StaticResource Theme_TextSecondary}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>