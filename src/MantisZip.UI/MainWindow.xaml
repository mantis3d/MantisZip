<Window x:Class="MantisZip.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:app="clr-namespace:MantisZip.UI"
             xmlns:l="clr-namespace:MantisZip.UI.Localization"
        mc:Ignorable="d"
        Title="{l:L Main_WindowTitle}" Icon="/Resources/App.ico" Height="800" Width="1200"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Background="#F5F5F5"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
        </Style>

        <!-- 选中项失焦时的高亮颜色（默认浅灰几乎看不见） -->
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#CCE0F0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="White">
            <MenuItem Header="{l:L Main_Menu_File}">
                <MenuItem Header="{l:L Main_Menu_OpenArchive}" Click="OpenArchive_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="{l:L Main_Menu_NewArchive}" Click="NewArchive_Click" InputGestureText="Ctrl+N"/>
                <Separator/>
                <MenuItem Header="{l:L Main_Menu_Extract}" Click="Extract_Click" InputGestureText="Ctrl+E"/>
                <MenuItem Header="{l:L Main_Menu_Compress}" Click="Compress_Click" InputGestureText="Ctrl+C"/>
                <Separator/>
                <MenuItem Header="{l:L Main_Menu_Exit}" Click="Exit_Click" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="{l:L Main_Menu_View}">
                <MenuItem Header="{l:L Main_Menu_Refresh}" Click="Refresh_Click" InputGestureText="F5"/>
            </MenuItem>
            <MenuItem Header="{l:L Main_Menu_Tools}">
                <MenuItem Header="{l:L Main_Menu_PasswordManager}" Click="PasswordManager_Click"/>
                <Separator/>
                <MenuItem Header="{l:L Main_Menu_Settings}" Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="{l:L Main_Menu_Help}">
                <MenuItem Header="{l:L Main_Menu_About}" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="1" Background="White">
            <ToolBar Band="0" BandIndex="0">
                <Button ToolTip="{l:L Main_Tooltip_NewArchive}" Click="NewArchive_Click" Padding="6,4">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="🆕" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_New}" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button ToolTip="{l:L Main_Tooltip_OpenArchive}" Click="OpenArchive_Click" Padding="6,4">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="📂" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_Open}" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button ToolTip="{l:L Main_Tooltip_Extract}" Click="Extract_Click" Padding="6,4">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="📤" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Extract}" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button ToolTip="{l:L Main_Tooltip_Compress}" Click="Compress_Click" Padding="6,4">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="📥" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Shell_Compress}" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button ToolTip="{l:L Main_Tooltip_Test}" Click="TestArchive_Click" Padding="6,4">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="✓" FontSize="18" Foreground="Green" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Main_Toolbar_Test}" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button x:Name="EnterPasswordBtn" ToolTip="{l:L Main_Tooltip_Password}" Click="EnterPassword_Click" Padding="6,4" IsEnabled="False">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="🔑" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L PwdMgr_Col_Password}" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <ToggleButton x:Name="PreviewToggleBtn" ToolTip="{l:L Main_Tooltip_Preview}" Click="PreviewToggleBtn_Click" Padding="6,4">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock x:Name="PreviewToggleIcon" Text="👁" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock Text="{l:L Settings_Tab_Preview}" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
            </ToolBar>
        </ToolBarTray>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="8">
            <Border Background="White" CornerRadius="4" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- No Archive Loaded - Drop Hint -->
                    <Border x:Name="DropHint" Grid.Row="1" Visibility="Visible"
                            Background="#FAFAFA" BorderBrush="#AAA" BorderThickness="2" CornerRadius="8">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📁" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="{l:L Main_EmptyDropHint}" FontSize="16" Foreground="Gray" Margin="0,16,0,4"/>
                            <Button Content="{l:L Main_OpenArchiveBtn}" FontSize="14" Click="OpenArchive_Click" 
                                    Background="Transparent" BorderThickness="0" Foreground="#2196F3" Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <!-- Archive Loaded - File List -->
                    <Grid x:Name="FileListPanel" Grid.Row="1" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Archive Info -->
                        <Border Grid.Row="0" Background="#E3F2FD" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="ArchiveNameText" Text="" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock x:Name="ArchiveInfoText" Text="" FontSize="11" Foreground="Gray"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- TreeView + FileList + Preview -->
                        <Grid Grid.Row="1" x:Name="ContentGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" MinWidth="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="100"/>
                                <ColumnDefinition x:Name="PreviewColSplitterDef" Width="Auto" MinWidth="0"/>
                                <ColumnDefinition x:Name="PreviewColumnDef" Width="0" MinWidth="0"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition x:Name="PreviewSplitterRow" Height="0"/>
                                <RowDefinition x:Name="PreviewRow" Height="0"/>
                            </Grid.RowDefinitions>

                            <!-- TreeView + DataGrid -->
                            <Grid x:Name="InnerContentGrid" Grid.Row="0" Grid.ColumnSpan="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition x:Name="InnerPreviewSplitterRow" Height="0"/>
                                    <RowDefinition x:Name="InnerPreviewRow" Height="0"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="TreeColumn" Width="396" MinWidth="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition x:Name="FileListColumn" Width="*" MinWidth="100"/>
                                    <ColumnDefinition x:Name="InnerPreviewColSplitterDef" Width="Auto" MinWidth="0"/>
                                    <ColumnDefinition x:Name="InnerPreviewColumnDef" Width="0" MinWidth="0"/>
                                </Grid.ColumnDefinitions>

                                <!-- Directory Tree -->
                                <TreeView x:Name="FolderTree" Grid.Column="0" 
                                          BorderThickness="1" BorderBrush="#DDD"
                                          SelectedItemChanged="FolderTree_SelectedItemChanged"
                                          ItemContainerStyle="{StaticResource TreeViewItemStyle}">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding Name}"/>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>

                                <GridSplitter x:Name="TreeFileSplitter" Grid.Column="1" Width="4" Background="Transparent" 
                                            HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                                <!-- File List -->
                                <DataGrid x:Name="FileListGrid" Grid.Column="2"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Extended"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          Background="White"
                                          VirtualizingStackPanel.IsVirtualizing="True"
                                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                                          EnableRowVirtualization="True"
                                          ScrollViewer.IsDeferredScrollingEnabled="False"
                                          BorderThickness="1"
                                          BorderBrush="#DDD"
                                            SelectionChanged="FileListGrid_SelectionChanged"
                                           PreviewMouseDoubleClick="FileListGrid_PreviewMouseDoubleClick"
                                           PreviewMouseLeftButtonDown="FileListGrid_PreviewMouseLeftButtonDown"
                                           PreviewMouseMove="FileListGrid_PreviewMouseMove">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{l:L Main_Ctx_ExtractTo}" Click="FileListCtx_ExtractTo"/>
                                            <MenuItem Header="{l:L Main_Ctx_ExtractHere}" Click="FileListCtx_ExtractHere"/>
                                            <Separator/>
                                            <MenuItem Header="{l:L Main_Ctx_CopyName}" Click="FileListCtx_CopyName"/>
                                            <MenuItem Header="{l:L Main_Ctx_CopyPath}" Click="FileListCtx_CopyPath"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="{l:L Main_Col_Name}" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding NameDisplay}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="{l:L Main_Col_Size}" Binding="{Binding SizeDisplay}" Width="100"/>
                                        <DataGridTextColumn Header="{l:L Main_Col_Compressed}" Binding="{Binding CompressedSizeDisplay}" Width="100"/>
                                        <DataGridTextColumn Header="{l:L Main_Col_Date}" Binding="{Binding DateDisplay}" Width="150"/>
                                        <DataGridTemplateColumn Header="{l:L Main_Col_Encrypted}" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="🔒" HorizontalAlignment="Center" 
                                                               Visibility="{Binding IsEncrypted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Inner preview row splitter (Pos 2/3) -->
                                <GridSplitter x:Name="InnerPreviewSplitter" Grid.Row="1"
                                            Height="4" Background="Transparent"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                            Visibility="Collapsed" Grid.ColumnSpan="5"/>
                            </Grid>

                            <!-- Vertical Splitter for Pos 4 (Right preview) -->
                            <GridSplitter x:Name="PreviewColSplitter" Grid.Row="0" Grid.Column="3"
                                        Width="4" Background="Transparent"
                                        HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                        Visibility="Collapsed"/>

                            <!-- Preview Splitter -->
                            <GridSplitter x:Name="PreviewSplitter" Grid.Row="1" Grid.ColumnSpan="5" Height="4" 
                                        Background="Transparent" HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center" Visibility="Collapsed"/>

                            <!-- Preview Panel -->
                            <Border x:Name="PreviewPanel" Grid.Row="2" Grid.ColumnSpan="5"
                                    Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"
                                    CornerRadius="4" Visibility="Collapsed">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <TextBlock x:Name="PreviewHeader" Grid.Row="0"
                                              FontWeight="SemiBold" FontSize="12" Foreground="#666"
                                              VerticalAlignment="Top" HorizontalAlignment="Left"/>

                                    <!-- Content area + Info Panel (dual orientation) -->
                                    <Grid x:Name="PreviewContentGrid" Grid.Row="1" Margin="0,16,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Image Preview -->
                                            <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed"/>

                                            <!-- File Icon (for non-previewable files) -->
                                            <Image x:Name="PreviewFileIcon" Width="64" Height="64" Visibility="Collapsed"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Text Preview -->
                                            <TextBox x:Name="PreviewTextBox"
                                                     IsReadOnly="True" 
                                                     FontFamily="Cascadia Code, Consolas, monospace"
                                                     FontSize="12"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     TextWrapping="Wrap"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     Visibility="Collapsed"/>

                                            <!-- HTML/Markdown Preview -->
                                            <WebBrowser x:Name="PreviewWebBrowser" Visibility="Collapsed"/>

                                            <!-- Loading progress -->
                                            <StackPanel x:Name="PreviewLoadingPanel"
                                                        Visibility="Collapsed"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock x:Name="PreviewLoadingText"
                                                           Text="..."
                                                           FontSize="13" Foreground="#888"
                                                           HorizontalAlignment="Center"/>
                                                <ProgressBar Width="200" Height="8"
                                                             IsIndeterminate="True"
                                                             Margin="0,8,0,0"
                                                             Foreground="#2196F3"/>
                                                <TextBlock x:Name="PreviewLoadingPercent"
                                                           Text=""
                                                           FontSize="11" Foreground="#AAA"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <!-- Unsupported fallback -->
                                            <TextBlock x:Name="PreviewUnsupported"
                                                       Text="{l:L Preview_Unsupported}"
                                                       FontSize="14" Foreground="#999"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="Collapsed"/>

                                            <!-- Info Panel (universal) -->
                                            <Border x:Name="PreviewInfoPanel"
                                                    Background="#F0F0F0" CornerRadius="4" 
                                                    Padding="10" Margin="12,0,0,0"
                                                    MinWidth="160" MinHeight="60">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Row 0: Format-specific info -->
                                                    <TextBlock x:Name="PreviewFormatInfo" Grid.Row="0" Grid.ColumnSpan="3"
                                                               FontSize="12" Foreground="#555"
                                                               TextWrapping="Wrap" Margin="0,0,0,4"/>

                                                    <!-- Row 1: Separator -->
                                                    <Rectangle Grid.Row="1" Grid.ColumnSpan="3"
                                                               Height="1" Fill="#DDD" Margin="0,0,0,4"/>

                                                    <!-- Row 2: File name -->
                                                    <TextBlock x:Name="PreviewFileNameText" Grid.Row="2" Grid.ColumnSpan="3"
                                                               FontWeight="SemiBold" Foreground="#333" FontSize="12"
                                                               TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>

                                                    <!-- Row 3: Separator -->
                                                    <Rectangle Grid.Row="3" Grid.ColumnSpan="3"
                                                               Height="1" Fill="#DDD" Margin="0,0,0,4"/>

                                                    <!-- Row 4: Size / Ratio / Compressed -->
                                                    <TextBlock x:Name="PreviewSizeText" Grid.Row="4" Grid.Column="0"
                                                               FontSize="11" Foreground="#555"/>
                                                    <TextBlock x:Name="PreviewCompressedText" Grid.Row="4" Grid.Column="1"
                                                               FontSize="11" Foreground="#555"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock x:Name="PreviewRatioText" Grid.Row="4" Grid.Column="2"
                                                               FontSize="11" Foreground="#555"
                                                               HorizontalAlignment="Right"/>

                                                    <!-- Row 5: Date + Encrypted -->
                                                    <TextBlock x:Name="PreviewDateText" Grid.Row="5" Grid.Column="0"
                                                               FontSize="11" Foreground="#555"/>
                                                    <TextBlock x:Name="PreviewEncryptedText" Grid.Row="5" Grid.Column="2"
                                                               FontSize="11" Foreground="#555"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

<!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="#E0E0E0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- Status Text (left) -->
            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusText" Text="{l:L Main_Status_Ready}"/>
            </StatusBarItem>

            <!-- Column 1 = spacer (*) fills center -->

            <!-- Dir Stats -->
            <StatusBarItem Grid.Column="2">
                <TextBlock x:Name="DirStatsText" Margin="4,0,4,0" Foreground="#555"/>
            </StatusBarItem>

            <!-- Selection Stats -->
            <StatusBarItem Grid.Column="3">
                <TextBlock x:Name="SelectionStatsText" Margin="4,0,4,0" Foreground="#555"/>
            </StatusBarItem>

            <!-- Archive Overview -->
            <StatusBarItem Grid.Column="4">
                <TextBlock x:Name="ArchiveStatsText" Margin="4,0,4,0" Foreground="#555"/>
            </StatusBarItem>

            <!-- Password Status -->
            <StatusBarItem Grid.Column="5">
                <TextBlock x:Name="PasswordStatusText" Margin="4,0,4,0" Foreground="#555" FontSize="11"/>
            </StatusBarItem>

            <!-- Progress -->
            <StatusBarItem Grid.Column="6">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar x:Name="ProgressBar" Width="120" Height="14" Visibility="Collapsed"/>
                    <TextBlock x:Name="ProgressText" Margin="4,0,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Version (far right) -->
            <StatusBarItem Grid.Column="7">
                <TextBlock Text="{x:Static app:AppConstants.VersionDisplay}" Foreground="#666"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>