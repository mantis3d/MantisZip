<Window x:Class="MantisZip.UI.PasswordHelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="匹配规则帮助 - MantisZip" Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- 简介 -->
            <TextBlock Text="匹配规则说明" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="22">
                匹配规则用于自动判断某个压缩包应该使用哪个密码打开。
                每条密码可配置多条规则，任意一条匹配即生效。
                支持 Glob 和正则表达式两种匹配方式，按顺序尝试，优先作为正则表达式匹配。
            </TextBlock>

            <!-- Glob 匹配 -->
            <TextBlock Text="一、Glob 匹配（通配符）" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="White" CornerRadius="4" Padding="14" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="通配符" FontWeight="Bold" Width="120"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="含义" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="  *" FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="匹配任意字符（包括空）"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="  ?" FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="匹配单个任意字符"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="  ." FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="匹配句点（需要写出来）"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="  其他字符" FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="原样匹配自身"/>
                    </Grid>

                    <TextBlock Text="范例" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#FAFAFA" CornerRadius="4" Padding="10" BorderBrush="#EEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="*.zip" FontWeight="Bold" Foreground="#2196F3"/>
                                <Run Text="  →  匹配所有 .zip 文件"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="文档*" FontWeight="Bold" Foreground="#2196F3"/>
                                <Run Text="  →  匹配「文档」「文档v2」「文档-最终版」等"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="???.zip" FontWeight="Bold" Foreground="#2196F3"/>
                                <Run Text="  →  匹配「abc.zip」「123.zip」，不匹配「ab.zip」"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13">
                                <Run Text="备份-202?-*.7z" FontWeight="Bold" Foreground="#2196F3"/>
                                <Run Text="  →  匹配「备份-2023-01.7z」「备份-2024-财务.7z」等"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Regex 匹配 -->
            <TextBlock Text="二、正则表达式匹配" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="White" CornerRadius="4" Padding="14" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="22">
                        如果 Glob 不够用，可以直接写正则表达式。
                        系统会优先尝试作为正则表达式匹配，匹配失败（语法错误）才降级为 Glob。
                        匹配时忽略大小写（不区分 a/A）。
                    </TextBlock>

                    <TextBlock Text="常用符号" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="表达式" FontWeight="Bold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="含义" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="  \d" FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="数字 0-9"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="  \w" FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="字母、数字、下划线"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="  [a-z]" FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="字符集，匹配其中任意一个"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="  ^...$" FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="从头匹配到结尾"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="  |" FontFamily="Consolas" Foreground="#2196F3"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="或，匹配左侧或右侧"/>
                    </Grid>

                    <TextBlock Text="范例" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#FAFAFA" CornerRadius="4" Padding="10" BorderBrush="#EEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="^财务" FontWeight="Bold" Foreground="#2196F3"/>
                                <Run Text="  →  匹配以「财务」开头的文件"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="\.rar$" FontWeight="Bold" Foreground="#2196F3"/>
                                <Run Text="  →  匹配所有 .rar 后缀的文件"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,0,0,4">
                                <Run Text="202[0-9]\.zip" FontWeight="Bold" Foreground="#2196F3"/>
                                <Run Text="  →  匹配「2020.zip」到「2029.zip」"/>
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13">
                                <Run Text="(项目A|项目B)-\d+" FontWeight="Bold" Foreground="#2196F3"/>
                                <Run Text="  →  匹配「项目A-001」「项目B-99」等"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 匹配顺序说明 -->
            <TextBlock Text="三、匹配逻辑" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="White" CornerRadius="4" Padding="14" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,6">
                        1. 打开压缩包时，系统提取文件名，逐个检查每条密码的匹配规则。  
                        2. 每条规则先尝试作为正则表达式匹配。  
                        3. 如果正则表达式抛出异常（语法错误），自动降级为 Glob 匹配。  
                        4. 任意一条规则匹配成功 → 该密码被列入候选列表。  
                        5. 多条密码匹配时，弹出列表供你选择。
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 关闭按钮 -->
            <Button Content="知道了" Click="Close_Click" Width="100" Height="32" 
                    HorizontalAlignment="Right" IsDefault="True"
                    Background="#2196F3" Foreground="White" Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>
</Window>
