<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MantisZip.UI.Avalonia.ViewModels"
             xmlns:models="clr-namespace:MantisZip.UI.Avalonia.Models"
             x:Class="MantisZip.UI.Avalonia.Views.PreviewPanel"
             x:DataType="vm:PreviewViewModel">
  <Grid RowDefinitions="Auto,*">
    <!-- Toolbar -->
    <Border Grid.Row="0"
            Padding="4,2"
            Background="{DynamicResource ThemeHeaderBgBrush}"
            IsVisible="{Binding IsToolbarVisible}">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <!-- Zoom controls (image/gif) -->
        <StackPanel Orientation="Horizontal" Spacing="2"
                    IsVisible="{Binding HasZoomControls}">
          <Button Content="−" Command="{Binding ZoomOutCommand}"
                  Width="32" Height="28" FontSize="16" Padding="0" />
          <Button Content="+" Command="{Binding ZoomInCommand}"
                  Width="32" Height="28" FontSize="16" Padding="0" />
          <Button Content="⟲" Command="{Binding ZoomFitCommand}"
                  Width="32" Height="28" FontSize="14" Padding="0" />
        </StackPanel>

        <!-- Font size controls (text) -->
        <StackPanel Orientation="Horizontal" Spacing="2"
                    IsVisible="{Binding HasFontSizeControls}">
          <Button Content="A−" Command="{Binding DecreaseFontSizeCommand}"
                  Width="36" Height="28" FontSize="13" Padding="0" />
          <Button Content="A+" Command="{Binding IncreaseFontSizeCommand}"
                  Width="36" Height="28" FontSize="13" Padding="0" />
        </StackPanel>

        <!-- GIF controls -->
        <StackPanel Orientation="Horizontal" Spacing="2"
                    IsVisible="{Binding HasGifControls}">
          <Button Content="⏮" Command="{Binding PreviousGifFrameCommand}"
                  Width="32" Height="28" FontSize="16" Padding="0" />
          <Button Content="⏯" Command="{Binding PlayPauseGifCommand}"
                  Width="32" Height="28" FontSize="16" Padding="0" />
          <Button Content="⏭" Command="{Binding NextGifFrameCommand}"
                  Width="32" Height="28" FontSize="16" Padding="0" />
          <TextBox Text="{Binding CurrentFrame}"
                   Width="36" Height="26"
                   FontSize="14"
                   VerticalContentAlignment="Center"
                   HorizontalContentAlignment="Center" />
          <TextBlock Text="{Binding TotalFrames, StringFormat=/ {0}}"
                     FontSize="14"
                     VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Preview content area - will be populated by Tasks 6-11 -->
    <ScrollViewer Grid.Row="1"
                  Background="{DynamicResource ThemeSurfaceBgBrush}">
      <Grid>
        <!-- Unsupported / empty state -->
        <TextBlock Text="{Binding TextContent}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   IsVisible="{Binding IsUnsupportedVisible}" />

        <!-- Text preview -->
        <ScrollViewer IsVisible="{Binding IsTextVisible}">
          <TextBox Text="{Binding TextContent}"
                   IsReadOnly="True"
                   TextWrapping="Wrap"
                   FontFamily="Consolas"
                   FontSize="{Binding FontSize}"
                   Background="{DynamicResource ThemeSurfaceBgBrush}"
                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                   BorderThickness="0" />
        </ScrollViewer>

        <!-- CSV preview -->
        <ScrollViewer IsVisible="{Binding IsCsvVisible}">
          <DataGrid ItemsSource="{Binding CsvData}"
                    AutoGenerateColumns="True"
                    IsReadOnly="True"
                    CanUserResizeColumns="True" />
        </ScrollViewer>

        <!-- PE preview -->
        <StackPanel IsVisible="{Binding IsPeVisible}"
                    Spacing="8">
          <TextBlock Text="{Binding PeTitle}"
                     FontSize="20"
                     FontWeight="Bold" />
          <TextBlock Text="{Binding PeSubtitle}"
                     FontSize="13"
                     Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
          <Separator />
          <ItemsControl ItemsSource="{Binding PeMetadata}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:PeMetadataItem">
                <Grid ColumnDefinitions="Auto,8,*"
                      Margin="0,2">
                  <TextBlock Text="{Binding Key}"
                             FontWeight="Bold"
                             Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding Value}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Image preview -->
        <ScrollViewer IsVisible="{Binding IsImageVisible}"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
          <Image Source="{Binding PreviewImage}"
                 RenderTransformOrigin="0,0">
            <Image.RenderTransform>
              <ScaleTransform ScaleX="{Binding ZoomLevel}"
                              ScaleY="{Binding ZoomLevel}" />
            </Image.RenderTransform>
          </Image>
        </ScrollViewer>

        <!-- GIF preview (same image control) -->
        <ScrollViewer IsVisible="{Binding IsGifVisible}"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
          <Image Source="{Binding PreviewImage}"
                 RenderTransformOrigin="0,0">
            <Image.RenderTransform>
              <ScaleTransform ScaleX="{Binding ZoomLevel}"
                              ScaleY="{Binding ZoomLevel}" />
            </Image.RenderTransform>
          </Image>
        </ScrollViewer>

        <!-- SVG preview -->
        <ScrollViewer IsVisible="{Binding IsSvgVisible}">
          <Image Source="{Binding PreviewImage}" />
        </ScrollViewer>

        <!-- Font preview -->
        <ScrollViewer IsVisible="{Binding IsFontVisible}">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding PreviewHeaderText}"
                       FontSize="20"
                       FontWeight="Bold" />
            <ItemsControl ItemsSource="{Binding FormatMetadata}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:FormatMetadataItem">
                  <Grid ColumnDefinitions="Auto,8,*" Margin="0,2">
                    <TextBlock Text="{Binding Key}" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                    <TextBlock Grid.Column="2" Text="{Binding Value}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Separator />
            <TextBlock Text="{Binding TextContent}"
                       FontFamily="{Binding FontFamily}"
                       FontSize="16"
                       TextWrapping="Wrap" />
          </StackPanel>
        </ScrollViewer>

        <!-- Audio preview (metadata only) -->
        <StackPanel IsVisible="{Binding IsAudioVisible}"
                    Spacing="8">
          <TextBlock Text="{Binding PreviewHeaderText}"
                     FontSize="20"
                     FontWeight="Bold" />
          <ItemsControl ItemsSource="{Binding FormatMetadata}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:FormatMetadataItem">
                <Grid ColumnDefinitions="Auto,8,*" Margin="0,2">
                  <TextBlock Text="{Binding Key}" FontWeight="Bold"
                             Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                  <TextBlock Grid.Column="2" Text="{Binding Value}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- SQLite preview -->
        <Grid IsVisible="{Binding IsSqliteVisible}"
              RowDefinitions="Auto,*">
          <TabControl Grid.Row="0"
                      ItemsSource="{Binding SqliteTableNames}"
                      SelectedIndex="{Binding SelectedTableIndex}">
            <TabControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" />
              </DataTemplate>
            </TabControl.ItemTemplate>
          </TabControl>
          <DataGrid Grid.Row="1"
                    ItemsSource="{Binding SqliteTableData}"
                    AutoGenerateColumns="True"
                    IsReadOnly="True"
                    CanUserResizeColumns="True" />
        </Grid>

        <!-- ISO preview (metadata only) -->
        <StackPanel IsVisible="{Binding IsIsoVisible}"
                    Spacing="8">
          <TextBlock Text="{Binding PreviewHeaderText}"
                     FontSize="20"
                     FontWeight="Bold" />
          <ItemsControl ItemsSource="{Binding FormatMetadata}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:FormatMetadataItem">
                <Grid ColumnDefinitions="Auto,8,*" Margin="0,2">
                  <TextBlock Text="{Binding Key}" FontWeight="Bold"
                             Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                  <TextBlock Grid.Column="2" Text="{Binding Value}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Torrent preview -->
        <ScrollViewer IsVisible="{Binding IsTorrentVisible}">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding PreviewHeaderText}"
                       FontSize="20"
                       FontWeight="Bold" />
            <ItemsControl ItemsSource="{Binding FormatMetadata}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:FormatMetadataItem">
                  <Grid ColumnDefinitions="Auto,8,*" Margin="0,2">
                    <TextBlock Text="{Binding Key}" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                    <TextBlock Grid.Column="2" Text="{Binding Value}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Separator />
            <TextBlock Text="文件列表" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding TorrentFileItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TorrentFileItem">
                  <Grid ColumnDefinitions="*,80" Margin="0,1">
                    <TextBlock Text="{Binding Path}" />
                    <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>

        <!-- Office preview (metadata only) -->
        <StackPanel IsVisible="{Binding IsOfficeVisible}"
                    Spacing="8">
          <TextBlock Text="{Binding PreviewHeaderText}"
                     FontSize="20"
                     FontWeight="Bold" />
          <ItemsControl ItemsSource="{Binding FormatMetadata}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:FormatMetadataItem">
                <Grid ColumnDefinitions="Auto,8,*" Margin="0,2">
                  <TextBlock Text="{Binding Key}" FontWeight="Bold"
                             Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                  <TextBlock Grid.Column="2" Text="{Binding Value}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Video preview (metadata only) -->
        <StackPanel IsVisible="{Binding IsVideoVisible}"
                    Spacing="8">
          <TextBlock Text="{Binding PreviewHeaderText}"
                     FontSize="20"
                     FontWeight="Bold" />
          <ItemsControl ItemsSource="{Binding FormatMetadata}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:FormatMetadataItem">
                <Grid ColumnDefinitions="Auto,8,*" Margin="0,2">
                  <TextBlock Text="{Binding Key}" FontWeight="Bold"
                             Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                  <TextBlock Grid.Column="2" Text="{Binding Value}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Grid>
</UserControl>
