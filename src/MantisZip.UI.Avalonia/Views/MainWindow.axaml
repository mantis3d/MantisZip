<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MantisZip.UI.Avalonia.ViewModels"
        xmlns:models="clr-namespace:MantisZip.UI.Avalonia.Models"
        xmlns:conv="clr-namespace:MantisZip.UI.Avalonia.Converters"
        x:Class="MantisZip.UI.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="500">
  <Window.Resources>
    <conv:FileSizeConverter x:Key="FileSizeConverter" />
  </Window.Resources>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Menu -->
    <Menu Grid.Row="0">
      <MenuItem Header="文件">
        <MenuItem Header="打开压缩包"
                  Command="{Binding OpenArchiveCommand}" />
        <Separator />
        <MenuItem Header="退出" />
      </MenuItem>
    </Menu>

    <!-- Main content: file list + preview -->
    <Grid Grid.Row="1"
          ColumnDefinitions="2.5*,5,3*">
      <!-- File list header + items -->
      <Grid Grid.Column="0"
            RowDefinitions="Auto,*">
        <!-- Column header -->
        <Grid ColumnDefinitions="*,80,70,100"
              Margin="4,4,4,0">
          <TextBlock Text="名称" FontWeight="SemiBold" />
          <TextBlock Grid.Column="1" Text="大小" FontWeight="SemiBold" />
          <TextBlock Grid.Column="2" Text="压缩后" FontWeight="SemiBold" />
          <TextBlock Grid.Column="3" Text="修改日期" FontWeight="SemiBold" />
        </Grid>

        <!-- File items -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Entries}"
                 SelectedItem="{Binding SelectedEntry}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:ArchiveItemModel">
              <Grid ColumnDefinitions="*,80,70,100"
                    Margin="2,0">
                <TextBlock Text="{Binding NameDisplay}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="{Binding SizeDisplay}" />
                <TextBlock Grid.Column="2"
                           Text="{Binding CompressedSizeDisplay}" />
                <TextBlock Grid.Column="3"
                           Text="{Binding LastModifiedDisplay}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <GridSplitter Grid.Column="1"
                    Width="5" />

      <!-- Preview area -->
      <Border Grid.Column="2"
              Padding="8">
        <Grid>
          <!-- Unsupported / empty state -->
          <TextBlock Text="{Binding Preview.TextContent}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap"
                     IsVisible="{Binding Preview.IsUnsupportedVisible}" />

          <!-- Text preview -->
          <ScrollViewer IsVisible="{Binding Preview.IsTextVisible}">
            <TextBox Text="{Binding Preview.TextContent}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     FontSize="13"
                     Background="Transparent"
                     BorderThickness="0" />
          </ScrollViewer>

          <!-- CSV preview -->
          <ScrollViewer IsVisible="{Binding Preview.IsCsvVisible}">
            <ItemsControl ItemsSource="{Binding Preview.CsvData}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,1">
                    <ItemsControl ItemsSource="{Binding Row.ItemArray}"
                                  x:CompileBindings="False">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border BorderBrush="Gray"
                                  BorderThickness="0,0,1,0"
                                  Padding="6,2">
                            <TextBlock Text="{Binding}"
                                       FontFamily="Consolas"
                                       FontSize="12" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <!-- PE preview -->
          <StackPanel IsVisible="{Binding Preview.IsPeVisible}"
                      Spacing="8">
            <TextBlock Text="{Binding Preview.PeTitle}"
                       FontSize="20"
                       FontWeight="Bold" />
            <TextBlock Text="{Binding Preview.PeSubtitle}"
                       FontSize="13"
                       Foreground="#888" />
            <Separator />
            <ItemsControl ItemsSource="{Binding Preview.PeMetadata}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PeMetadataItem">
                  <Grid ColumnDefinitions="Auto,8,*"
                        Margin="0,2">
                    <TextBlock Text="{Binding Key}"
                               FontWeight="Bold"
                               Foreground="#666" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Value}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Padding="8,4">
      <TextBlock Text="{Binding StatusMessage}" />
    </Border>
  </Grid>
</Window>
