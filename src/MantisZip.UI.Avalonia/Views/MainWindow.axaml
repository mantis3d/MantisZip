<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MantisZip.UI.Avalonia.ViewModels"
        xmlns:models="clr-namespace:MantisZip.UI.Avalonia.Models"
         xmlns:conv="clr-namespace:MantisZip.UI.Avalonia.Converters"
         xmlns:views="clr-namespace:MantisZip.UI.Avalonia.Views"
        x:Class="MantisZip.UI.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="500"
        Background="{DynamicResource ThemeWindowBgBrush}">
  <Window.Styles>
    <Style Selector="GridSplitter">
      <Setter Property="Background" Value="{DynamicResource ThemeSplitterBgBrush}" />
    </Style>
    <Style Selector="Menu">
      <Setter Property="Background" Value="{DynamicResource ThemeHeaderBgBrush}" />
    </Style>
    <Style Selector="ScrollViewer">
      <Setter Property="Background" Value="{DynamicResource ThemeWindowBgBrush}" />
    </Style>
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{DynamicResource ThemeListBgBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}" />
    </Style>
  </Window.Styles>

  <Window.Resources>
    <conv:FileSizeConverter x:Key="FileSizeConverter" />
  </Window.Resources>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Menu -->
    <Menu Grid.Row="0">
      <MenuItem Header="文件">
        <MenuItem Header="打开压缩包"
                  Command="{Binding OpenArchiveCommand}" />
        <Separator />
        <MenuItem Header="退出" />
      </MenuItem>
      <MenuItem Header="视图">
        <MenuItem Header="切换暗色主题"
                  Command="{Binding ToggleThemeCommand}" />
      </MenuItem>
    </Menu>

    <!-- Main content: TreeView | file list | preview -->
    <Grid Grid.Row="1"
          ColumnDefinitions="Auto,5,2.5*,5,3*">
      <!-- Folder tree -->
      <Border Grid.Column="0"
              Width="220"
              Background="{DynamicResource ThemeSurfaceBgBrush}">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Text="浏览"
                     Margin="8,6"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
          <TreeView Grid.Row="1"
                    ItemsSource="{Binding FolderTreeRoot.Children}"
                    SelectedItem="{Binding SelectedFolder}"
                    BorderThickness="0"
                    Background="Transparent">
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Spacing="4"
                            Margin="4,2">
                  <TextBlock Text="{Binding Name}"
                             Foreground="{DynamicResource ThemeTextPrimaryBrush}" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="5" />

      <!-- File list as DataGrid -->
      <DataGrid Grid.Column="2"
                ItemsSource="{Binding CurrentEntries}"
                SelectedItem="{Binding SelectedEntry}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="" Width="22">
            <DataTemplate>
              <Image Source="{Binding IconSource}"
                     Width="16" Height="16"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center" />
            </DataTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="名称"
                              Binding="{Binding NameDisplay}"
                              Width="*" />
          <DataGridTextColumn Header="大小"
                              Binding="{Binding SizeDisplay}"
                              Width="80" />
          <DataGridTextColumn Header="压缩后"
                              Binding="{Binding CompressedSizeDisplay}"
                              Width="70" />
          <DataGridTextColumn Header="修改日期"
                              Binding="{Binding LastModifiedDisplay}"
                              Width="100" />
        </DataGrid.Columns>
      </DataGrid>

      <GridSplitter Grid.Column="3"
                    Width="5" />

      <!-- Preview area -->
      <views:PreviewPanel Grid.Column="4"
                          DataContext="{Binding Preview}" />
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Padding="8,4"
            Background="{DynamicResource ThemeHeaderBgBrush}">
      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="{DynamicResource ThemeTextPrimaryBrush}" />
    </Border>
  </Grid>
</Window>
