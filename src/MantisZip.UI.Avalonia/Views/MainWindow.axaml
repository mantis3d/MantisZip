<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MantisZip.UI.Avalonia.ViewModels"
        xmlns:models="clr-namespace:MantisZip.UI.Avalonia.Models"
        xmlns:conv="clr-namespace:MantisZip.UI.Avalonia.Converters"
        x:Class="MantisZip.UI.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="500">
  <Window.Resources>
    <conv:FileSizeConverter x:Key="FileSizeConverter" />
  </Window.Resources>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Menu -->
    <Menu Grid.Row="0">
      <MenuItem Header="文件">
        <MenuItem Header="打开压缩包"
                  Command="{Binding OpenArchiveCommand}" />
        <Separator />
        <MenuItem Header="退出" />
      </MenuItem>
    </Menu>

    <!-- Main content: file list + preview -->
    <Grid Grid.Row="1"
          ColumnDefinitions="2.5*,5,3*">
      <!-- File list as DataGrid -->
      <DataGrid Grid.Column="0"
                ItemsSource="{Binding Entries}"
                SelectedItem="{Binding SelectedEntry}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Header="名称"
                              Binding="{Binding NameDisplay}"
                              Width="*" />
          <DataGridTextColumn Header="大小"
                              Binding="{Binding SizeDisplay}"
                              Width="80" />
          <DataGridTextColumn Header="压缩后"
                              Binding="{Binding CompressedSizeDisplay}"
                              Width="70" />
          <DataGridTextColumn Header="修改日期"
                              Binding="{Binding LastModifiedDisplay}"
                              Width="100" />
        </DataGrid.Columns>
      </DataGrid>

      <GridSplitter Grid.Column="1"
                    Width="5" />

      <!-- Preview area -->
      <Border Grid.Column="2"
              Padding="8">
        <Grid>
          <!-- Unsupported / empty state -->
          <TextBlock Text="{Binding Preview.TextContent}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap"
                     IsVisible="{Binding Preview.IsUnsupportedVisible}" />

          <!-- Text preview -->
          <ScrollViewer IsVisible="{Binding Preview.IsTextVisible}">
            <TextBox Text="{Binding Preview.TextContent}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     FontSize="13"
                     Background="Transparent"
                     BorderThickness="0" />
          </ScrollViewer>

          <!-- CSV preview -->
          <ScrollViewer IsVisible="{Binding Preview.IsCsvVisible}">
            <DataGrid ItemsSource="{Binding Preview.CsvData}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      CanUserResizeColumns="True" />
          </ScrollViewer>

          <!-- PE preview -->
          <StackPanel IsVisible="{Binding Preview.IsPeVisible}"
                      Spacing="8">
            <TextBlock Text="{Binding Preview.PeTitle}"
                       FontSize="20"
                       FontWeight="Bold" />
            <TextBlock Text="{Binding Preview.PeSubtitle}"
                       FontSize="13"
                       Foreground="#888" />
            <Separator />
            <ItemsControl ItemsSource="{Binding Preview.PeMetadata}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PeMetadataItem">
                  <Grid ColumnDefinitions="Auto,8,*"
                        Margin="0,2">
                    <TextBlock Text="{Binding Key}"
                               FontWeight="Bold"
                               Foreground="#666" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Value}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Padding="8,4">
      <TextBlock Text="{Binding StatusMessage}" />
    </Border>
  </Grid>
</Window>
